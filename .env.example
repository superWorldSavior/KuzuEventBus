# Root-level environment for docker-compose
# Copy to .env and fill secrets.

# Postgres superuser password (used by postgres:15-alpine entrypoint)
POSTGRES_PASSWORD=change-me-strong-password

# Graph engine selection (kuzu|rust)
GRAPH_ENGINE=kuzu
# Rust engine endpoint (used by API when GRAPH_ENGINE=rust)
ENGINE_ENDPOINT=http://engine:9400
