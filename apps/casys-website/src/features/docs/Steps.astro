---
export interface Props { title?: string }
const { title } = Astro.props as Props;
---
<section style="border:3px solid var(--sl-color-gray-6);border-radius:12px;box-shadow:6px 6px 0 var(--sl-color-accent-low);padding:0.85rem 1rem;">
  {title && (<h4 style="margin:0 0 .35rem 0;font-weight:800;">{title}</h4>)}
  <ol style="counter-reset: step; list-style: none; margin: 0; padding: 0; display: grid; gap: .6rem;">
    <slot />
  </ol>
</section>

<style>
  :global(ol > li.step) {
    counter-increment: step;
    padding-left: 2.25rem;
    position: relative;
  }
  :global(ol > li.step)::before {
    content: counter(step);
    position: absolute; left: 0; top: .1rem;
    width: 1.6rem; height: 1.6rem; border-radius: 50%;
    display: grid; place-items: center;
    background: var(--sl-color-accent);
    color: #fff; font-weight: 800;
    border: 2px solid var(--sl-color-gray-6);
    box-shadow: 2px 2px 0 var(--sl-color-accent-low);
  }
</style>
