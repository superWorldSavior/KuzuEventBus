---
import I18n from '../i18n/I18n.astro';
---

<section id="branching" class="branching">
  <div class="branching__container">
    <div class="branching__header">
      <h2 class="branching__title" style="color: var(--text-primary);">
        <I18n>
          <Fragment slot="en">Branching & Time Travel</Fragment>
          <Fragment slot="fr">Branches & Voyage dans le Temps</Fragment>
        </I18n>
      </h2>
      <p class="branching__subtitle" style="color: var(--text-secondary);">
        <I18n>
          <Fragment slot="en">Point-in-Time Recovery and Git-like branches for your graph data</Fragment>
          <Fragment slot="fr">Point-in-Time Recovery et branches Git-like pour vos données graphe</Fragment>
        </I18n>
      </p>
    </div>

    <div class="branching__grid">
      <!-- Left: Visualization -->
      <div class="branching__left">
        <!-- Git-like Branch Diagram (Mermaid, responsive) -->
        <div class="branching__chart">
          <div id="branch-graph" style="min-height: 320px;"></div>
        </div>
        <script is:inline>
          (async () => {
            try {
              const mermaid = window.mermaid || (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
              if (!window.mermaid) window.mermaid = mermaid;
              mermaid.initialize({ 
                startOnLoad: false, 
                securityLevel: 'loose', 
                theme: 'forest',
                themeVariables: {
                  primaryColor: '#f3e8ff',
                  primaryTextColor: '#1f2937',
                  primaryBorderColor: '#7C4BB2',
                  lineColor: '#7C4BB2',
                  textColor: '#1f2937',
                  tertiaryColor: '#e9d5ff',
                  fontSize: '12px',
                  fontFamily: 'ui-sans-serif, system-ui, sans-serif'
                }
              });

              const graph = `gitGraph BT:\n  %% Historique initial de main\n  commit id: "c1"\n  commit id: "c2" tag: "r1"\n\n  %% PITR: recovery depuis c2 (r1)\n  branch recovery\n  checkout recovery\n  commit id: "r2"\n\n  %% main continue -> c3\n  checkout main\n  commit id: "c3"\n\n  %% dev part de c3\n  branch dev\n  checkout dev\n  commit id: "e1" tag: "e1"\n  commit id: "d2"\n\n  %% merge dev -> main\n  checkout main\n  merge dev\n\n  %% promotion: recovery (r1) devient la base de main\n  merge recovery tag: "promote r1"\n\n  %% HEAD final\n  commit id: "c4" tag: "HEAD"`;

              const { svg } = await mermaid.render('branch-graph-svg', graph);
              const el = document.getElementById('branch-graph');
              if (el) {
                el.innerHTML = svg;
                const svgEl = el.querySelector('svg');
                if (svgEl) {
                  svgEl.style.maxWidth = '100%';
                  svgEl.style.height = '100%';
                }
                const right = document.getElementById('branch-right-col');
                const sync = () => {
                  if (!right) return;
                  if (window.matchMedia('(min-width: 1024px)').matches) {
                    const h = right.getBoundingClientRect().height;
                    if (h > 0) el.style.height = `${h}px`;
                  } else {
                    el.style.height = 'auto';
                  }
                };
                sync();
                if (window.ResizeObserver && right) {
                  const ro = new ResizeObserver(() => sync());
                  ro.observe(right);
                }
                window.addEventListener('resize', sync);
              }
            } catch (e) { console.error('Mermaid render failed', e); }
          })();
        </script>
      </div>

      <!-- Right: Code Examples with Tabs -->
      <div id="branch-right-col" class="branching__right">
        <!-- Tabs -->
        <div class="branching__tabs" role="tablist" aria-label="Branching examples">
          <button id="branch-tab-branch" type="button" class="branching__tab active" data-tab="branch" role="tab" aria-selected="true" aria-controls="branch-tabpanel-branch" tabindex="0">
            <I18n>
              <Fragment slot="en">Create Branches</Fragment>
              <Fragment slot="fr">Créer des Branches</Fragment>
            </I18n>
          </button>
          <button id="branch-tab-pitr" type="button" class="branching__tab" data-tab="pitr" role="tab" aria-selected="false" aria-controls="branch-tabpanel-pitr" tabindex="-1">
            <I18n>
              <Fragment slot="en">PITR</Fragment>
              <Fragment slot="fr">PITR</Fragment>
            </I18n>
          </button>
          <button id="branch-tab-snapshot" type="button" class="branching__tab" data-tab="snapshot" role="tab" aria-selected="false" aria-controls="branch-tabpanel-snapshot" tabindex="-1">
            <I18n>
              <Fragment slot="en">Snapshots</Fragment>
              <Fragment slot="fr">Snapshots</Fragment>
            </I18n>
          </button>
        </div>

        <!-- Code blocks -->
        <div class="branching__content-wrapper">
          <!-- Create Branches -->
          <div id="branch-tabpanel-branch" class="branching__content active" data-content="branch" role="tabpanel" aria-labelledby="branch-tab-branch" aria-hidden="false">
            <pre class="branching__code-block"><code class="language-python"><span class="comment"># Créer une branche depuis main</span>
<span class="keyword">import</span> casys_db

engine = casys_db.CasysEngine(data_dir=<span class="string">"~/.casys_db"</span>)
db = engine.open_database(<span class="string">"social"</span>)

<span class="comment"># Créer une branche "main" si elle n'existe pas</span>
engine.create_branch(<span class="string">"social"</span>, <span class="string">"main"</span>)

<span class="comment"># Créer une branche expérimentale depuis main</span>
engine.create_branch(<span class="string">"social"</span>, <span class="string">"experiment"</span>)

<span class="comment"># Travailler sur experiment sans affecter main</span>
exp_branch = engine.open_branch(<span class="string">"social"</span>, <span class="string">"experiment"</span>)
result = exp_branch.query(<span class="string">"""
  CREATE (p:Person {'{'} name: 'Test User' {'}'})
  RETURN p
"""</span>)

<span class="comment"># main reste inchangé !</span>
</code></pre>
          </div>

          <!-- PITR -->
          <div id="branch-tabpanel-pitr" class="branching__content" data-content="pitr" role="tabpanel" aria-labelledby="branch-tab-pitr" aria-hidden="true">
            <pre class="branching__code-block"><code class="language-python"><span class="comment"># Point-in-Time Recovery</span>
<span class="keyword">from</span> casys_db <span class="keyword">import</span> Database

db = Database(<span class="string">"social.db"</span>)

<span class="comment"># Voir l'historique des modifications</span>
history = db.history(from_time=<span class="string">"yesterday"</span>)
<span class="keyword">for</span> event <span class="keyword">in</span> history:
    <span class="function">print</span>(f<span class="string">"{'{'} event.timestamp {'}'}: {'{'} event.type {'}'}"</span>)

<span class="comment"># Créer une branche depuis un point dans le passé</span>
recovery = db.branch_at(
    name=<span class="string">"recovery"</span>,
    timestamp=<span class="string">"2 hours ago"</span>
)

<span class="comment"># Explorer cet état passé (lecture seule)</span>
result = recovery.query(<span class="string">"MATCH (u:User) RETURN count(u)"</span>)
<span class="function">print</span>(f<span class="string">"Utilisateurs à ce moment: {'{'} result {'}'}"</span>)
</code></pre>
          </div>

          <!-- Snapshots -->
          <div id="branch-tabpanel-snapshot" class="branching__content" data-content="snapshot" role="tabpanel" aria-labelledby="branch-tab-snapshot" aria-hidden="true">
            <pre class="branching__code-block"><code class="language-python"><span class="comment"># Snapshots et persistence</span>
<span class="keyword">import</span> casys_db

engine = casys_db.CasysEngine(data_dir=<span class="string">"~/.casys_db"</span>)
db = engine.open_database(<span class="string">"social"</span>)
branch = engine.open_branch(<span class="string">"social"</span>, <span class="string">"main"</span>)

<span class="comment"># Créer des données</span>
branch.query(<span class="string">"""
  CREATE (u:User {'{'} name: 'Alice', age: 30 {'}'})
"""</span>)

<span class="comment"># Persister les changements sur disque</span>
branch.flush()  <span class="comment"># → Write segments + WAL</span>

<span class="comment"># Créer un snapshot explicite</span>
timestamp = engine.snapshot(branch, <span class="keyword">None</span>)
<span class="function">print</span>(f<span class="string">"Snapshot créé: {'{'} timestamp {'}'}"</span>)

<span class="comment"># Recharger depuis le disque</span>
branch.load()
</code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="branching__features">
      <div class="branching__feature">
        <div class="branching__feature-icon">🌳</div>
        <h3 class="branching__feature-title" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Isolated Branches</Fragment>
            <Fragment slot="fr">Branches Isolées</Fragment>
          </I18n>
        </h3>
        <p class="branching__feature-text" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Test changes safely. Each branch is completely isolated.</Fragment>
            <Fragment slot="fr">Testez des changements sans risque. Chaque branche est complètement isolée.</Fragment>
          </I18n>
        </p>
      </div>

      <div class="branching__feature">
        <div class="branching__feature-icon">⏰</div>
        <h3 class="branching__feature-title" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Time Travel</Fragment>
            <Fragment slot="fr">Voyage dans le Temps</Fragment>
          </I18n>
        </h3>
        <p class="branching__feature-text" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Create a branch from any past commit. Debug easily.</Fragment>
            <Fragment slot="fr">Créez une branche depuis n'importe quel commit passé. Débugguez facilement.</Fragment>
          </I18n>
        </p>
      </div>

      <div class="branching__feature">
        <div class="branching__feature-icon">📸</div>
        <h3 class="branching__feature-title" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Auto Snapshots</Fragment>
            <Fragment slot="fr">Snapshots Auto</Fragment>
          </I18n>
        </h3>
        <p class="branching__feature-text" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Each commit = snapshot. No data loss, complete history.</Fragment>
            <Fragment slot="fr">Chaque commit = snapshot. Aucune perte de données, historique complet.</Fragment>
          </I18n>
        </p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@use '~/styles/variables' as *;
@use '~/styles/mixins' as *;

.branching {
  padding: 5rem 0;
  background: var(--bg-main);

  &__container { @include container; }

  &__header { text-align: center; margin-bottom: 3rem; }
  &__title { font-size: $text-4xl; font-weight: 700; }
  &__subtitle { margin-top: 1rem; font-size: $text-xl; }

  &__grid {
    display: grid;
    gap: 3rem;
    align-items: center;
    @include lg { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  &__chart {
    width: 100%;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    border: 1px solid var(--border);
    background: color-mix(in oklab, var(--surface) 80%, transparent);
    border-radius: 1rem;
    padding: 1rem;
    box-shadow: 0 1px 2px rgba(0,0,0,.05);
  }

  &__tabs {
    display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1.5rem;
  }

  &__tab {
    padding: .75rem 1.5rem;
    border-radius: .75rem;
    font-weight: 600;
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;

    &:hover { border-color: $acc; }
    &.active { background: var(--acc-soft); color: var(--text-primary); border-color: $acc; }

    &:focus-visible { outline: 2px solid $acc; outline-offset: 2px; }
  }

  &__code-block {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: .5rem;
    padding: 1.5rem;
    overflow-x: auto;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: .9rem;
    line-height: 1.6;
  }

  &__content { display: none; &.active { display: block; animation: fadeIn .3s ease-in; } }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* Syntax highlighting */
  .keyword { color: #c678dd; font-weight: 600; }
  .string { color: #98c379; }
  .comment { color: #5c6370; font-style: italic; }
  .function { color: #61afef; }
  .type { color: #e5c07b; }
  .number { color: #d19a66; }

  &__features { display: grid; gap: 1.5rem; margin-top: 4rem; @include md { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  &__feature { @include card; text-align: center; padding: 1.5rem; border-radius: .75rem; }
  &__feature-icon { font-size: $text-4xl; margin-bottom: .75rem; }
  &__feature-title { font-weight: 700; font-size: $text-lg; margin-bottom: .5rem; }
  &__feature-text { font-size: $text-sm; color: var(--text-secondary); }
}
</style>

<script>
const branchTabs = Array.from(document.querySelectorAll('.branching__tab'));
const branchPanels = Array.from(document.querySelectorAll('.branching__content'));

const activateBranchTab = (tab) => {
  if (!tab) return;
  const targetTab = tab.getAttribute('data-tab');
  if (!targetTab) return;

  branchTabs.forEach((btn) => {
    const isActive = btn === tab;
    btn.classList.toggle('active', isActive);
    btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    btn.setAttribute('tabindex', isActive ? '0' : '-1');
  });

  branchPanels.forEach((panel) => {
    const isMatch = panel.getAttribute('data-content') === targetTab;
    panel.classList.toggle('active', isMatch);
    panel.setAttribute('aria-hidden', isMatch ? 'false' : 'true');
  });
};

branchTabs.forEach((tab) => {
  tab.addEventListener('click', () => activateBranchTab(tab));
  tab.addEventListener('keydown', (event) => {
    const key = event && 'key' in event ? event.key : '';
    if (key === 'ArrowRight' || key === 'ArrowLeft') {
      event.preventDefault();
      const direction = key === 'ArrowRight' ? 1 : -1;
      const index = branchTabs.indexOf(tab);
      const nextIndex = (index + direction + branchTabs.length) % branchTabs.length;
      const nextTab = branchTabs[nextIndex];
      if (nextTab && typeof nextTab.focus === 'function') nextTab.focus();
      activateBranchTab(nextTab);
    }
  });
});
</script>
