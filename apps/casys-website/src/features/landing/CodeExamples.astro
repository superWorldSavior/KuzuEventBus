---
import I18n from '../i18n/I18n.astro';
---

<section id="examples" class="codeex">
  <div class="codeex__container">
    <div class="codeex__header">
      <h2 class="codeex__title" style="color: var(--text-primary);">
        <I18n>
          <Fragment slot="en">CasysDB in Action</Fragment>
          <Fragment slot="fr">CasysDB en action</Fragment>
        </I18n>
      </h2>
      <p class="codeex__subtitle" style="color: var(--text-secondary);">
        <I18n>
          <Fragment slot="en">Powerful graph queries with ISO GQL, fluent Python ORM</Fragment>
          <Fragment slot="fr">Requêtes graphe puissantes avec ISO GQL, ORM fluent en Python</Fragment>
        </I18n>
      </p>
    </div>

    <!-- Tabs -->
    <div class="codeex__tabs" role="tablist" aria-label="Code example languages">
      <button id="code-tab-create" type="button" class="codeex__tab active" data-tab="create" role="tab" aria-selected="true" aria-controls="code-tabpanel-create" tabindex="0">
        <I18n>
          <Fragment slot="en">Create Graph</Fragment>
          <Fragment slot="fr">Créer un graphe</Fragment>
        </I18n>
      </button>
      <button id="code-tab-query" type="button" class="codeex__tab" data-tab="query" role="tab" aria-selected="false" aria-controls="code-tabpanel-query" tabindex="-1">
        <I18n>
          <Fragment slot="en">GQL Query</Fragment>
          <Fragment slot="fr">Query GQL</Fragment>
        </I18n>
      </button>
      <button id="code-tab-orm" type="button" class="codeex__tab" data-tab="orm" role="tab" aria-selected="false" aria-controls="code-tabpanel-orm" tabindex="-1">
        <I18n>
          <Fragment slot="en">Python ORM</Fragment>
          <Fragment slot="fr">ORM Python</Fragment>
        </I18n>
      </button>
      <button id="code-tab-relations" type="button" class="codeex__tab" data-tab="relations" role="tab" aria-selected="false" aria-controls="code-tabpanel-relations" tabindex="-1">
        <I18n>
          <Fragment slot="en">Relationships</Fragment>
          <Fragment slot="fr">Relations</Fragment>
        </I18n>
      </button>
    </div>

    <!-- Code blocks -->
    <div class="codeex__content-wrapper">
      <!-- Create Graph -->
      <div id="code-tabpanel-create" class="codeex__content active" data-content="create" role="tabpanel" aria-labelledby="code-tab-create" aria-hidden="false">
        <pre class="codeex__code-block"><code class="language-python"><span class="comment"># Create nodes and relationships</span>
<span class="keyword">from</span> casys_db <span class="keyword">import</span> Database

db = Database(<span class="string">"social_network.db"</span>)
session = db.default_branch().session()

<span class="comment"># Create Person nodes</span>
session.execute(<span class="string">"""
  CREATE (alice:Person {'{'} name: 'Alice', age: 30 {'}'})
  CREATE (bob:Person {'{'} name: 'Bob', age: 25 {'}'})
  CREATE (carol:Person {'{'} name: 'Carol', age: 28 {'}'})
  
  CREATE (alice)-[:KNOWS {'{'} since: 2020 {'}'} ]->(bob)
  CREATE (alice)-[:KNOWS {'{'} since: 2019 {'}'} ]->(carol)
  CREATE (bob)-[:KNOWS {'{'} since: 2021 {'}'} ]->(carol)
  RETURN alice, bob, carol
"""</span>)

session.commit()
</code></pre>
      </div>

      <!-- GQL Query -->
      <div id="code-tabpanel-query" class="codeex__content" data-content="query" role="tabpanel" aria-labelledby="code-tab-query" aria-hidden="true">
        <pre class="codeex__code-block"><code class="language-sql"><span class="comment">-- Find friends of friends (2-hop path)</span>
<span class="keyword">MATCH</span> (person:<span class="type">Person</span>)-[:<span class="type">KNOWS</span>*<span class="number">2</span>]->(friend_of_friend:<span class="type">Person</span>)
<span class="keyword">WHERE</span> person.name = <span class="string">'Alice'</span>
  <span class="keyword">AND</span> person &lt;&gt; friend_of_friend
<span class="keyword">RETURN</span> friend_of_friend.name, 
       <span class="function">COUNT</span>(*) <span class="keyword">AS</span> paths
<span class="keyword">GROUP BY</span> friend_of_friend.name
<span class="keyword">ORDER BY</span> paths <span class="keyword">DESC</span>;

<span class="comment">-- Find people who know each other (mutual connections)</span>
<span class="keyword">MATCH</span> (p1:<span class="type">Person</span>)-[:<span class="type">KNOWS</span>]->(p2:<span class="type">Person</span>)-[:<span class="type">KNOWS</span>]->(p1)
<span class="keyword">WHERE</span> p1.name &lt; p2.name
<span class="keyword">RETURN</span> p1.name, p2.name;
</code></pre>
      </div>

      <!-- Python ORM -->
      <div id="code-tabpanel-orm" class="codeex__content" data-content="orm" role="tabpanel" aria-labelledby="code-tab-orm" aria-hidden="true">
        <pre class="codeex__code-block"><code class="language-python"><span class="comment"># Fluent query builder (ORM-style)</span>
<span class="keyword">from</span> casys_db <span class="keyword">import</span> NodeEntity, Session

<span class="keyword">class</span> <span class="type">Person</span>(NodeEntity):
    <span class="keyword">pass</span>

session = Session(db.default_branch())

<span class="comment"># Find all adults</span>
adults = session.Person.where(<span class="keyword">lambda</span> p: p.age >= <span class="number">18</span>).all()

<span class="comment"># Complex filtering with projections</span>
results = (
    session.Person
    .where(<span class="keyword">lambda</span> p: p.age > <span class="number">25</span>)
    .select_fields(<span class="string">'name'</span>, <span class="string">'age'</span>)
    .order_by(<span class="keyword">lambda</span> p: p.age, desc=<span class="keyword">True</span>)
    .limit(<span class="number">10</span>)
    .all()
)

<span class="keyword">for</span> person <span class="keyword">in</span> results:
    <span class="function">print</span>(f<span class="string">"{'{'} person['name'] {'}'}: {'{'} person['age'] {'}'}"</span>)
</code></pre>
      </div>

      <!-- Relationships -->
      <div id="code-tabpanel-relations" class="codeex__content" data-content="relations" role="tabpanel" aria-labelledby="code-tab-relations" aria-hidden="true">
        <pre class="codeex__code-block"><code class="language-python"><span class="comment"># Define entity relationships</span>
<span class="keyword">from</span> casys_db <span class="keyword">import</span> NodeEntity, HasMany, HasOne
<span class="keyword">from</span> typing <span class="keyword">import</span> Self

<span class="keyword">class</span> <span class="type">Person</span>(NodeEntity):
    knows = HasMany(Self)  <span class="comment"># Self-referential relationship</span>
    lives_in = HasOne(<span class="string">'City'</span>)

<span class="keyword">class</span> <span class="type">City</span>(NodeEntity):
    <span class="keyword">pass</span>

<span class="comment"># Query with joins</span>
results = (
    session.Person
    .where(<span class="keyword">lambda</span> p: p.name == <span class="string">'Alice'</span>)
    .join_out(<span class="keyword">lambda</span> p: p.knows)  <span class="comment"># Follow KNOWS relationship</span>
    .select(
        person=<span class="keyword">lambda</span> p: p.name,
        friend=<span class="keyword">lambda</span> f: f.name
    )
    .all()
)

<span class="keyword">for</span> row <span class="keyword">in</span> results:
    <span class="function">print</span>(f<span class="string">"{'{'} row['person'] {'}'} knows {'{'} row['friend'] {'}'}"</span>)
</code></pre>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@use '~/styles/variables' as *;
@use '~/styles/mixins' as *;

.codeex {
  padding: 6rem 0;
  background: var(--bg-benefits);

  @include lg {
    padding: 8rem 0;
  }

  &__container { @include container; }
  &__header { text-align: center; margin-bottom: 3rem; }
  &__title { font-size: $text-4xl; font-weight: 700; }
  &__subtitle { margin-top: 1rem; font-size: $text-xl; }

  &__tabs { display: flex; justify-content: center; gap: .75rem; flex-wrap: wrap; margin-bottom: 2rem; }
  &__tab {
    padding: 0.625rem 1.25rem;
    border-radius: $radius-md;
    font-weight: 600;
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    box-shadow: $shadow-sm;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    @include dark {
      box-shadow: $shadow-dark-sm;
    }

    &:hover { 
      border-color: $acc;
      box-shadow: $shadow-md;
      transform: translateY(-1px);

      @include dark {
        box-shadow: $shadow-dark-md;
      }
    }
    &.active { 
      background: var(--acc-soft);
      color: var(--text-primary);
      border-color: $acc;
      box-shadow: $shadow-md;

      @include dark {
        box-shadow: $shadow-dark-md;
      }
    }
    &:focus-visible { outline: 2px solid $acc; outline-offset: 2px; }
  }

  &__content-wrapper { width: 100%; min-width: 0; max-width: 64rem; margin: 0 auto; }
  &__content { display: none; &.active { display: block; animation: fadeIn .3s ease-in; } }
  &__code-block {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: $radius-lg;
    padding: 1.75rem;
    overflow-x: auto;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: .9rem;
    line-height: 1.6;
    box-shadow: $shadow-md;

    @include dark {
      box-shadow: $shadow-dark-md;
    }
  }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* Syntax highlighting */
  .keyword { color: #c678dd; font-weight: 600; }
  .string { color: #98c379; }
  .comment { color: #5c6370; font-style: italic; }
  .function { color: #61afef; }
  .type { color: #e5c07b; }
  .number { color: #d19a66; }
}
</style>

<script>
const codeTabs = Array.from(document.querySelectorAll('.codeex__tab'));
const codePanels = Array.from(document.querySelectorAll('.codeex__content'));

const activateCodeTab = (tab) => {
  const targetTab = tab.getAttribute('data-tab');
  if (!targetTab) return;

  codeTabs.forEach((btn) => {
    const isActive = btn === tab;
    btn.classList.toggle('active', isActive);
    btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    btn.tabIndex = isActive ? 0 : -1;
  });

  codePanels.forEach((panel) => {
    const isMatch = panel.getAttribute('data-content') === targetTab;
    panel.classList.toggle('active', isMatch);
    panel.setAttribute('aria-hidden', isMatch ? 'false' : 'true');
  });
};

codeTabs.forEach((tab, index) => {
  tab.addEventListener('click', () => activateCodeTab(tab));
  tab.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
      event.preventDefault();
      const direction = event.key === 'ArrowRight' ? 1 : -1;
      const nextIndex = (index + direction + codeTabs.length) % codeTabs.length;
      const nextTab = codeTabs[nextIndex];
      nextTab.focus();
      activateCodeTab(nextTab);
    }
  });
});
</script>
