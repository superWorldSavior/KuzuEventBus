---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import I18n from '../features/i18n/I18n.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;

// Récupérer les articles de blog pour la navigation
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Articles récents (5 derniers)
const recentPosts = sortedPosts.slice(0, 5);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || 'Général';
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Tags populaires
const allTags = sortedPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const popularTags = Object.entries(tagCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 10)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Blog CASYS - Articles et actualités" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="blog-layout">
    <!-- Nav bar de l'application -->
    <nav class="blog-layout__header">
      <div class="blog-layout__header-content">
        <!-- Logo et titre -->
        <div class="blog-layout__header-left">
          <div class="blog-layout__logo">
            <img src="/icons/favicon-32x32.png" alt="CASYS" class="blog-layout__logo-img" />
            <h1 class="blog-layout__logo-title">CASYS</h1>
            <span class="blog-layout__logo-subtitle">Blog</span>
          </div>
        </div>
        
        <!-- Navigation -->
        <div class="blog-layout__header-nav">
          <a 
            href="/blog" 
            class="blog-layout__header-link"
          >
            Blog
          </a>
          
          <!-- Séparateur -->
          <div class="blog-layout__header-divider"></div>
          
          <!-- Bouton retour landing -->
          <a 
            href="/" 
            class="blog-layout__header-link"
          >
            ← Accueil
          </a>
        </div>
      </div>
    </nav>
    
    <!-- Contenu principal avec nav bar -->
    <div class="blog-layout__main-wrapper">
      <!-- Sidebar de navigation blog -->
      <aside class="blog-layout__sidebar">
        <div class="blog-layout__sidebar-header">
          <h2 class="blog-layout__sidebar-title">📝 Blog CASYS</h2>
          <p class="blog-layout__sidebar-desc">
            Articles et actualités sur le développement
          </p>
        </div>
        
        <!-- Navigation du blog -->
        <nav class="blog-layout__sidebar-nav">
          <!-- Lien vers l'index -->
          <div>
            <a 
              href="/blog" 
              class={`blog-layout__sidebar-link ${
                currentPath === '/blog' || currentPath === '/blog/'
                  ? 'blog-layout__sidebar-link--active'
                  : ''
              }`}
            >
              🏠 Tous les articles
            </a>
          </div>
          
          <!-- Articles récents -->
          <div>
            <h3 class="blog-layout__sidebar-section-title">
              📅 Articles récents
            </h3>
            <ul class="blog-layout__sidebar-list">
              {recentPosts.map((post) => (
                <li>
                  <a 
                    href={`/blog/${post.slug}`}
                    class={`blog-layout__post-link ${
                      currentPath === `/blog/${post.slug}`
                        ? 'blog-layout__post-link--active'
                        : ''
                    }`}
                  >
                    <div class="blog-layout__post-title">{post.data.title}</div>
                    <div class="blog-layout__post-meta">
                      <span>{post.data.date.toLocaleDateString('fr-FR')}</span>
                      {post.data.category && (
                        <>
                          <span class="blog-layout__post-meta-sep">•</span>
                          <span>{post.data.category}</span>
                        </>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Catégories -->
          <div>
            <h3 class="blog-layout__sidebar-section-title">
              📁 Par catégorie
            </h3>
            <ul class="blog-layout__sidebar-list">
              {Object.entries(postsByCategory).map(([categoryName, posts]) => (
                <li>
                  <div class="blog-layout__category-header">
                    <span>{categoryName}</span>
                    <span class="blog-layout__category-count">
                      {posts.length}
                    </span>
                  </div>
                  <ul class="blog-layout__category-posts">
                    {posts.slice(0, 3).map((post) => (
                      <li>
                        <a 
                          href={`/blog/${post.slug}`}
                          class={`blog-layout__category-link ${
                            currentPath === `/blog/${post.slug}`
                              ? 'blog-layout__category-link--active'
                              : ''
                          }`}
                        >
                          <div class="blog-layout__category-title">{post.data.title}</div>
                        </a>
                      </li>
                    ))}
                    {posts.length > 3 && (
                      <li>
                        <span class="blog-layout__category-more">
                          +{posts.length - 3} autres
                        </span>
                      </li>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Tags populaires -->
          <div>
            <h3 class="blog-layout__sidebar-section-title">
              🏷️ Tags populaires
            </h3>
            <div class="blog-layout__tags-container">
              <div class="blog-layout__tags">
                {popularTags.map((tag) => (
                  <span class="blog-layout__tag">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="blog-layout__sidebar-actions">
            <div class="blog-layout__sidebar-actions-content">
              <button class="blog-layout__action-btn">
                🔍 Rechercher
              </button>
              <button class="blog-layout__action-btn">
                📧 S'abonner aux nouveautés
              </button>
            </div>
          </div>
        </nav>
      </aside>

      <!-- Contenu principal -->
      <main class="blog-layout__content">
        <div class="blog-layout__content-inner">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<style lang="scss">
@use '~/styles/variables' as *;
@use '~/styles/mixins' as *;

.blog-layout {
  min-height: 100vh;
  background: #f9fafb;
  overflow: hidden;

  &__header {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 1rem;

    &-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    &-nav {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    &-link {
      padding: 0.5rem 0.75rem;
      font-size: $text-sm;
      font-weight: 500;
      color: var(--text-secondary);
      transition: color 0.2s ease;

      &:hover {
        color: var(--text-primary);
      }
    }

    &-divider {
      width: 1px;
      height: 1.5rem;
      background: var(--border);
    }
  }

  &__logo {
    display: flex;
    align-items: center;

    &-img {
      width: 2rem;
      height: 2rem;
      margin-right: 0.5rem;
    }

    &-title {
      font-size: $text-xl;
      font-weight: 700;
      color: var(--text-primary);
    }

    &-subtitle {
      margin-left: 0.5rem;
      font-size: $text-sm;
      color: var(--text-muted);
    }
  }

  &__main-wrapper {
    display: flex;
    height: calc(100vh - 60px);
  }

  &__sidebar {
    width: 20rem;
    background: white;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;

    &-header {
      padding: 1rem;
      border-bottom: 1px solid var(--border);
    }

    &-title {
      font-size: $text-lg;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.25rem;
    }

    &-desc {
      font-size: $text-sm;
      color: var(--text-muted);
    }

    &-nav {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    &-section-title {
      font-size: $text-xs;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding: 0.5rem 0.75rem;
    }

    &-list {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &-link {
      display: block;
      padding: 0.5rem 0.75rem;
      border-radius: 0.375rem;
      font-weight: 500;
      color: var(--text-primary);
      transition: all 0.2s ease;

      &:hover {
        background: #f9fafb;
      }

      &--active {
        background: #eff6ff;
        color: #1d4ed8;
        border-left: 2px solid #1d4ed8;
      }
    }

    &-actions {
      border-top: 1px solid var(--border);
      padding-top: 1rem;

      &-content {
        padding: 0 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
    }
  }

  &__post {
    &-link {
      display: block;
      padding: 0.5rem 0.75rem;
      border-radius: 0.375rem;
      font-size: $text-sm;
      transition: all 0.2s ease;

      &:hover {
        background: #f9fafb;

        .blog-layout__post-title {
          color: var(--text-primary);
        }
      }

      &--active {
        background: #eff6ff;
        color: #1d4ed8;
        border-left: 2px solid #1d4ed8;
      }
    }

    &-title {
      font-weight: 500;
      color: var(--text-secondary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    &-meta {
      font-size: $text-xs;
      color: var(--text-muted);
      margin-top: 0.25rem;
      display: flex;
      align-items: center;

      &-sep {
        margin: 0 0.25rem;
      }
    }
  }

  &__category {
    &-header {
      padding: 0.25rem 0.75rem;
      font-size: $text-sm;
      font-weight: 500;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &-count {
      font-size: $text-xs;
      color: var(--text-muted);
      background: #f3f4f6;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
    }

    &-posts {
      margin-left: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &-link {
      display: block;
      padding: 0.25rem 0.5rem;
      border-radius: 0.25rem;
      font-size: $text-xs;
      transition: all 0.2s ease;
      color: var(--text-secondary);

      &:hover {
        background: #f9fafb;
        color: var(--text-primary);
      }

      &--active {
        background: #eff6ff;
        color: #1d4ed8;
      }
    }

    &-title {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    &-more {
      display: block;
      padding: 0.25rem 0.5rem;
      font-size: $text-xs;
      color: #9ca3af;
    }
  }

  &__tags {
    &-container {
      padding: 0 0.75rem;
    }

    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  &__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    font-size: $text-xs;
    font-weight: 500;
    background: #f3f4f6;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover {
      background: #e5e7eb;
    }
  }

  &__action-btn {
    width: 100%;
    text-align: left;
    padding: 0.5rem 0.75rem;
    font-size: $text-sm;
    color: var(--text-secondary);
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    background: transparent;
    border: none;
    cursor: pointer;

    &:hover {
      color: var(--text-primary);
      background: #f9fafb;
    }
  }

  &__content {
    flex: 1;
    overflow-y: auto;

    &-inner {
      max-width: 56rem;
      margin: 0 auto;
      padding: 2rem;
    }
  }
}
</style>
