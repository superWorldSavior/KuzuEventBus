---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro'
import I18n from '../features/i18n/I18n.astro';
export interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const siteUrl = import.meta.env.PUBLIC_SITE_URL as string | undefined;
const canonicalUrl = siteUrl ? new URL(pathname, siteUrl).toString() : undefined;
const ogLocale = 'en_US';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="CasysDB - An embedded graph database with ISO GQL support" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />
    <script>
      // Auto theme sync with system (no localStorage override)
      (function () {
        try {
          const root = document.documentElement;
          const mql = (window.matchMedia?.('(prefers-color-scheme: dark)') ?? null) as MediaQueryList | null;
          const apply = () => {
            if (mql?.matches) root.classList.add('dark');
            else root.classList.remove('dark');
            root.dataset.theme = root.classList.contains('dark') ? 'dark' : 'light';
          };
          apply();
          if (mql?.addEventListener) mql.addEventListener('change', apply as EventListener);
          else if ((mql as any)?.addListener) (mql as any).addListener(apply);
        } catch (_) { /* no-op */ }
      })();
    </script>
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="CasysDB - An embedded graph database with ISO GQL support" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="CasysDB - An embedded graph database with ISO GQL support" />
  </head>
  <body class="landing">
    <!-- Header -->
    <header class="landing__header">
      <div class="landing__header-container">
        <div class="landing__header-content">
          <!-- Logo -->
          <div class="landing__logo">
            <a href="/" class="landing__logo-link">
              <img src="/icons/logo.svg" class="landing__logo-img" alt="Casys Logo" />
              <span class="landing__logo-text">CasysDB</span>
            </a>
          </div>

          <!-- Navigation -->
          <nav class="landing__nav" aria-label="Primary">
            <a href="/docs/getting-started/installation/" class="landing__nav-link">
              <I18n>
                <Fragment slot="en">Documentation</Fragment>
                <Fragment slot="fr">Documentation</Fragment>
              </I18n>
            </a>
            <a href="#examples" class="landing__nav-link">
              <I18n>
                <Fragment slot="en">Examples</Fragment>
                <Fragment slot="fr">Exemples</Fragment>
              </I18n>
            </a>
            <a href="#branching" class="landing__nav-link">
              <I18n>
                <Fragment slot="en">Branches</Fragment>
                <Fragment slot="fr">Branches</Fragment>
              </I18n>
            </a>
            <a href="#use-cases" class="landing__nav-link">
              <I18n>
                <Fragment slot="en">Use Cases</Fragment>
                <Fragment slot="fr">Cas d'usage</Fragment>
              </I18n>
            </a>
            <a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="landing__nav-link landing__nav-link--icon">
              <svg class="landing__nav-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              <I18n>
                <Fragment slot="en">GitHub</Fragment>
                <Fragment slot="fr">GitHub</Fragment>
              </I18n>
            </a>
          </nav>

          <!-- Actions -->
          <div class="landing__actions">
            <button
              id="theme-toggle"
              type="button"
              class="landing__btn landing__btn--icon"
              aria-pressed="false"
              aria-label="Toggle theme"
            >
              <span class="visually-hidden">
                <I18n>
                  <Fragment slot="en">Toggle theme</Fragment>
                  <Fragment slot="fr">Changer le thème</Fragment>
                </I18n>
              </span>
              <span data-theme-icon="sun" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.75V3m0 18v-1.75M7.757 7.757 6.343 6.343m11.314 11.314-1.414-1.414M4.75 12H3m18 0h-1.75M7.757 16.243 6.343 17.657m11.314-11.314-1.414 1.414M12 8.25a3.75 3.75 0 1 1 0 7.5 3.75 3.75 0 0 1 0-7.5z" />
                </svg>
              </span>
              <span data-theme-icon="moon" class="hidden" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 0 1 11.21 3 7.5 7.5 0 1 0 21 12.79z" />
                </svg>
              </span>
            </button>
            <button
              id="mobile-nav-toggle"
              type="button"
              class="landing__btn landing__btn--icon landing__btn--mobile"
              aria-controls="mobile-nav"
              aria-expanded="false"
            >
              <span class="visually-hidden">
                <I18n>
                  <Fragment slot="en">Toggle navigation</Fragment>
                  <Fragment slot="fr">Ouvrir le menu</Fragment>
                </I18n>
              </span>
              <span data-menu-icon="open" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </span>
              <span data-menu-icon="close" class="hidden" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </span>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile navigation -->
      <div id="mobile-nav" class="landing__mobile" hidden>
        <div data-nav-overlay class="landing__overlay"></div>
        <nav class="landing__mobile-nav" aria-label="Mobile primary navigation">
          <ul class="landing__mobile-list">
            <li>
              <a href="/docs/getting-started/installation/" class="landing__mobile-link">
                <span>
                  <I18n>
                    <Fragment slot="en">Documentation</Fragment>
                    <Fragment slot="fr">Documentation</Fragment>
                  </I18n>
                </span>
              </a>
            </li>
            <li>
              <a href="#examples" class="landing__mobile-link">
                <span>
                  <I18n>
                    <Fragment slot="en">Examples</Fragment>
                    <Fragment slot="fr">Exemples</Fragment>
                  </I18n>
                </span>
              </a>
            </li>
            <li>
              <a href="#branching" class="landing__mobile-link">
                <span>
                  <I18n>
                    <Fragment slot="en">Branches</Fragment>
                    <Fragment slot="fr">Branches</Fragment>
                  </I18n>
                </span>
              </a>
            </li>
            <li>
              <a href="#use-cases" class="landing__mobile-link">
                <span>
                  <I18n>
                    <Fragment slot="en">Use Cases</Fragment>
                    <Fragment slot="fr">Cas d'usage</Fragment>
                  </I18n>
                </span>
              </a>
            </li>
            <li>
              <a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="landing__mobile-link">
                <span>
                  <I18n>
                    <Fragment slot="en">GitHub</Fragment>
                    <Fragment slot="fr">GitHub</Fragment>
                  </I18n>
                </span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="landing__footer">
      <div class="landing__footer-container">
        <div class="landing__footer-grid">
          <!-- Company Info -->
          <div class="landing__footer-main">
            <h3 class="landing__footer-title" style="color: var(--text-primary);">CasysDB</h3>
            <p class="landing__footer-desc" style="color: var(--text-secondary);">
              An embedded graph database with ISO GQL support. Built in Rust with native Python and TypeScript bindings.
              MVCC transactions, Point-in-Time Recovery, and a fluent ORM.
            </p>
            <p class="landing__footer-tagline" style="color: var(--text-muted);">
              Fast, embedded, and powerful graph database
            </p>
          </div>

          <!-- Product -->
          <div class="landing__footer-col">
            <h4 class="landing__footer-col-title" style="color: var(--text-primary);">
              <I18n>
                <Fragment slot="en">Product</Fragment>
                <Fragment slot="fr">Produit</Fragment>
              </I18n>
            </h4>
            <ul class="landing__footer-list">
              <li><a href="/docs/getting-started/installation/" class="landing__footer-link">Installation</a></li>
              <li><a href="/docs/getting-started/quickstart/" class="landing__footer-link">Quick Start</a></li>
              <li><a href="/docs/gql/basics/" class="landing__footer-link">GQL Syntax</a></li>
              <li><a href="#features" class="landing__footer-link">Features</a></li>
            </ul>
          </div>

          <!-- Community -->
          <div class="landing__footer-col">
            <h4 class="landing__footer-col-title" style="color: var(--text-primary);">
              <I18n>
                <Fragment slot="en">Community</Fragment>
                <Fragment slot="fr">Communauté</Fragment>
              </I18n>
            </h4>
            <ul class="landing__footer-list">
              <li><a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="landing__footer-link">GitHub</a></li>
              <li><a href="https://github.com/casysai/casysdb/issues" target="_blank" rel="noopener noreferrer" class="landing__footer-link">Issues</a></li>
              <li><a href="https://github.com/casysai/casysdb/discussions" target="_blank" rel="noopener noreferrer" class="landing__footer-link">Discussions</a></li>
              <li><a href="/docs/getting-started/installation/" class="landing__footer-link">Documentation</a></li>
            </ul>
          </div>
        </div>

        <div class="landing__footer-bottom">
          <p class="landing__footer-copy" style="color: var(--text-muted);">
            © 2025 CasysDB. Open-source under MIT License.
          </p>
          <div class="landing__footer-links">
            <a href="https://github.com/casysai/casysdb/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="landing__footer-bottom-link">MIT License</a>
            <a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="landing__footer-bottom-link">GitHub</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scripts pour les boutons -->
    <script>
      // Gestion du bouton de connexion (mock pour l'instant)
      document.getElementById('login-btn')?.addEventListener('click', () => {
        // Pour l'instant, redirection directe vers l'app
        // Plus tard : modal de connexion ou redirection vers auth
        window.location.href = '/app';
      });

      // Beta signup button handler
      document.getElementById('beta-signup-btn')?.addEventListener('click', () => {
        // For now: simple alert
        // Later: modal with form or API integration
        alert('Beta access request — coming soon!');
      });

      // Theme toggle handler with localStorage persistence
      (function () {
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const iconSun = btn.querySelector('[data-theme-icon="sun"]');
        const iconMoon = btn.querySelector('[data-theme-icon="moon"]');
        const syncState = () => {
          const isDark = root.classList.contains('dark');
          btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
          btn.dataset.theme = isDark ? 'dark' : 'light';
          iconSun?.classList.toggle('hidden', isDark);
          iconMoon?.classList.toggle('hidden', !isDark);
        };
        syncState();
        btn.addEventListener('click', () => {
          const isDark = root.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          root.dataset.theme = isDark ? 'dark' : 'light';
          syncState();
        });
      })();

      // Mobile navigation toggle
      (function () {
        const toggle = document.getElementById('mobile-nav-toggle');
        const menu = document.getElementById('mobile-nav');
        if (!toggle || !menu) return;
        const overlay = menu.querySelector('[data-nav-overlay]');
        const links = menu.querySelectorAll('a');
        const body = document.body;
        const iconOpen = toggle.querySelector('[data-menu-icon="open"]');
        const iconClose = toggle.querySelector('[data-menu-icon="close"]');

        const setState = (open) => {
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          menu.toggleAttribute('hidden', !open);
          body.classList.toggle('mobile-nav-open', open);
          iconOpen?.classList.toggle('hidden', open);
          iconClose?.classList.toggle('hidden', !open);
        };

        let isOpen = false;
        setState(false);

        const close = () => {
          if (!isOpen) return;
          isOpen = false;
          setState(false);
          toggle.focus();
        };

        const openMenu = () => {
          if (isOpen) return;
          isOpen = true;
          setState(true);
        };

        toggle.addEventListener('click', () => {
          if (isOpen) {
            close();
          } else {
            openMenu();
          }
        });

        overlay?.addEventListener('click', close);
        links.forEach((link) => link.addEventListener('click', close));
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            close();
          }
        });
      })();
    </script>

    <!-- Hide-on-scroll logic for header -->
    <script>
      (function () {
        const header = document.querySelector('header.landing__header');
        if (!header) return;
        let lastY = window.scrollY;
        let ticking = false;
        const threshold = 8; // pixels

        const onScroll = () => {
          const currentY = window.scrollY;
          const delta = currentY - lastY;
          const goingDown = delta > 0;
          const farFromTop = currentY > 10;
          if (Math.abs(delta) > threshold) {
            if (goingDown && farFromTop) {
              header.classList.add('hide-nav');
            } else {
              header.classList.remove('hide-nav');
            }
            lastY = currentY;
          }
          ticking = false;
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(onScroll);
            ticking = true;
          }
        }, { passive: true });
      })();
    </script>

    <style lang="scss">
      @use '~/styles/variables' as *;
      @use '~/styles/mixins' as *;

      .landing {
        min-height: 100vh;
        background: var(--bg-hero);

        &.mobile-nav-open {
          overflow: hidden;
        }

        // Header
        &__header {
          position: sticky;
          top: 0;
          z-index: 50;
          backdrop-filter: blur(12px) saturate(180%);
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          will-change: transform;
          border-bottom: 1px solid;
          border-radius: 0 0 $radius-lg $radius-lg;
          margin: 0.75rem 0.75rem 0 0.75rem;

          @include md {
            margin: 0;
            border-radius: 0;
          }

          :root:not(.dark) & {
            background: rgba(255, 255, 255, 0.8);
            border-color: rgba(17, 24, 39, 0.1);
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.04);
          }

          .dark & {
            background: rgba(15, 23, 42, 0.8);
            border-color: rgba(91, 46, 126, 0.2);
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.3);
          }

          &.hide-nav {
            transform: translateY(-100%);
          }
        }

        &__header-container {
          @include container;
        }

        &__header-content {
          @include flex-between;
          height: 4rem;
        }

        // Logo
        &__logo {
          display: flex;
          align-items: center;
        }

        &__logo-link {
          @include flex-center;
          gap: 0.75rem;
          text-decoration: none !important;

          &:focus-visible {
            outline: 2px solid $acc;
            outline-offset: 2px;
          }
        }

        &__logo-img {
          height: 2rem;
        }

        &__logo-text {
          font-size: $text-2xl;
          font-weight: 600;
          white-space: normal;
          word-break: break-word;
          line-height: 1.25;
          color: #111827;
          text-decoration: none;

          .dark & {
            color: white;
          }
        }

        // Navigation
        &__nav {
          display: none;
          align-items: center;
          gap: 2rem;

          @include md {
            display: flex;
          }
        }

        &__nav-link {
          padding: 0.5rem 0.75rem;
          border-radius: $radius-md;
          font-size: $text-sm;
          font-weight: 500;
          color: #1f2937;
          text-decoration: none;
          transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);

          .dark & {
            color: rgba(255, 255, 255, 0.8);
          }

          &:hover {
            color: $acc;
            background: rgba(91, 46, 126, 0.05);

            .dark & {
              color: $acc;
              background: rgba(91, 46, 126, 0.1);
            }
          }

          &:focus-visible {
            outline: 2px solid $acc;
            outline-offset: 2px;
          }

          &--icon {
            @include flex-center;
            gap: 0.25rem;
          }
        }

        &__nav-icon {
          width: 1rem;
          height: 1rem;
        }

        // Actions
        &__actions {
          display: flex;
          align-items: center;
          gap: 0.5rem;

          @include md {
            gap: 0.75rem;
          }
        }

        &__btn {
          @include flex-center;
          height: 2.5rem;
          width: 2.5rem;
          border-radius: 0.5rem;
          border: 1px solid transparent;
          transition: all 0.2s ease;

          &--icon {
            @include flex-center;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: $radius-md;
            background: transparent;
            border: 1px solid transparent;
            color: #6b7280;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 0.5rem;
            flex-shrink: 0;

            svg {
              width: 1.25rem;
              height: 1.25rem;
              stroke-width: 1.5;
            }

            .dark & {
              color: #d4d4d4;
            }

            &:hover {
              background: #f3f4f6;
              border-color: #e5e7eb;
              transform: scale(1.05);

              .dark & {
                background: rgba(255, 255, 255, 0.1);
                border-color: rgba(255, 255, 255, 0.2);
              }
            }

            &:active {
              transform: scale(0.95);
            }

            &:focus-visible {
              outline: 2px solid $acc;
              outline-offset: 2px;
            }
          }

          &--mobile {
            @include md {
              display: none;
            }
          }
        }

        // Mobile menu
        &__mobile {
          @include md {
            display: none;
          }
        }

        &__overlay {
          position: fixed;
          inset: 0;
          z-index: 40;
          background: rgba(0, 0, 0, 0.35);

          .dark & {
            background: rgba(0, 0, 0, 0.6);
          }
        }

        &__mobile-nav {
          position: fixed;
          inset: 1rem 1rem auto;
          top: 5rem;
          z-index: 50;
          overflow: hidden;
          border-radius: 1rem;
          border: 1px solid var(--border);
          background: color-mix(in oklab, var(--surface) 95%, transparent);
          box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
          backdrop-filter: blur(10px);
          color: var(--text-primary);
        }

        &__mobile-list {
          padding: 0.25rem 0;
        }

        &__mobile-link {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 0.75rem 1rem;
          font-size: $text-base;
          font-weight: 500;
          transition: background 0.2s ease;

          &:hover {
            background: var(--acc-soft);
          }

          &:focus-visible {
            outline: 2px solid $acc;
            outline-offset: 2px;
          }
        }

        // Footer
        &__footer {
          background: var(--bg-footer);
          border-top: 1px solid var(--border);
          padding: 4rem 0 3rem;
          margin-top: 6rem;

          a {
            text-decoration: none;
            transition: color 0.2s ease;

            &:hover {
              color: $acc;
            }
          }
        }

        &__footer-container {
          @include container;
          padding-top: 3rem;
          padding-bottom: 3rem;
        }

        &__footer-grid {
          display: grid;
          grid-template-columns: 1fr;
          gap: 2rem;

          @include md {
            grid-template-columns: repeat(4, minmax(0, 1fr));
          }
        }

        &__footer-main {
          grid-column: span 1;

          @include md {
            grid-column: span 2;
          }
        }

        &__footer-title {
          font-size: $text-lg;
          font-weight: 700;
          margin-bottom: 1rem;
        }

        &__footer-desc {
          margin-bottom: 1rem;
        }

        &__footer-tagline {
          font-size: $text-sm;
        }

        &__footer-col-title {
          font-size: $text-sm;
          font-weight: 600;
          margin-bottom: 1rem;
        }

        &__footer-list {
          display: flex;
          flex-direction: column;
          gap: 0.5rem;
          font-size: $text-sm;
        }

        &__footer-link {
          color: var(--text-secondary);
          transition: color 0.2s ease;

          &:hover {
            color: var(--text-primary);
          }
        }

        &__footer-bottom {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: space-between;
          margin-top: 2rem;
          padding-top: 2rem;
          border-top: 1px solid var(--card-border);

          @include md {
            flex-direction: row;
          }
        }

        &__footer-copy {
          font-size: $text-sm;
        }

        &__footer-links {
          display: flex;
          gap: 1.5rem;
          margin-top: 1rem;

          @include md {
            margin-top: 0;
          }
        }

        &__footer-bottom-link {
          font-size: $text-sm;
          color: var(--text-muted);
          transition: color 0.2s ease;

          &:hover {
            color: var(--text-primary);
          }
        }
      }

      // Utility
      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>

    <Analytics />
  </body>
