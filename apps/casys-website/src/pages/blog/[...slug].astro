---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export const prerender = true;

// Générer une page statique pour chaque article de blog
export async function getStaticPaths() {
  const blogPosts = await getCollection('blog', ({ data }) => {
    return !data.draft; // Exclure les brouillons
  });
  
  return blogPosts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Récupérer l'article pour la page actuelle
const { entry } = Astro.props;

if (!entry) {
  return Astro.redirect('/blog');
}

const { Content } = await entry.render();

// Récupérer les articles similaires (même catégorie ou tags)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(post => 
    post.slug !== entry.slug && (
      post.data.category === entry.data.category ||
      post.data.tags.some(tag => entry.data.tags.includes(tag))
    )
  )
  .slice(0, 3);
---

<BlogLayout title={entry.data.title}>
  <!-- Navigation retour -->
  <nav class="blog-post__back-nav">
    <a 
      href="/blog" 
      class="blog-post__back-link"
    >
      ← Retour au blog
    </a>
  </nav>

  <!-- En-tête de l'article -->
  <header class="blog-post__header">
    <div class="blog-post__category-wrapper">
      {entry.data.category && (
        <span class="blog-post__category">
          {entry.data.category}
        </span>
      )}
    </div>
    
    <h1 class="blog-post__title">
      {entry.data.title}
    </h1>
    
    {entry.data.description && (
      <p class="blog-post__description">
        {entry.data.description}
      </p>
    )}
    
    <!-- Métadonnées -->
    <div class="blog-post__meta">
      <div class="blog-post__meta-item">
        <span class="blog-post__meta-icon">📅</span>
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('fr-FR', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>
      
      <div class="blog-post__meta-item">
        <span class="blog-post__meta-icon">✍️</span>
        <span>{entry.data.author}</span>
      </div>
      
      {entry.data.updatedAt && (
        <div class="blog-post__meta-item">
          <span class="blog-post__meta-icon">🔄</span>
          <span>
            Mis à jour le {entry.data.updatedAt.toLocaleDateString('fr-FR')}
          </span>
        </div>
      )}
    </div>
    
    <!-- Tags -->
    {entry.data.tags.length > 0 && (
      <div class="blog-post__tags-wrapper">
        <div class="blog-post__tags">
          {entry.data.tags.map((tag) => (
            <span class="blog-post__tag">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </header>

  <!-- Contenu de l'article -->
  <article class="blog-post__content prose prose-lg">
    <Content />
  </article>

  <!-- Articles similaires -->
  {relatedPosts.length > 0 && (
    <section class="blog-post__related">
      <h2 class="blog-post__related-title">Articles similaires</h2>
      
      <div class="blog-post__related-grid">
        {relatedPosts.map((post) => (
          <article class="blog-post__related-card">
            <div class="blog-post__related-card-content">
              <h3 class="blog-post__related-card-title">
                <a href={`/blog/${post.slug}`} class="blog-post__related-card-link">
                  {post.data.title}
                </a>
              </h3>
              
              <div class="blog-post__related-card-date">
                {post.data.date.toLocaleDateString('fr-FR')}
              </div>
              
              {post.data.description && (
                <p class="blog-post__related-card-desc">
                  {post.data.description}
                </p>
              )}
              
              <div class="blog-post__related-card-tags">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="blog-post__related-tag">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            
            <a 
              href={`/blog/${post.slug}`}
              class="blog-post__related-card-read-more"
            >
              Lire l'article →
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Navigation suivant/précédent -->
  <nav class="blog-post__bottom-nav">
    <div class="blog-post__bottom-nav-content">
      <div class="blog-post__bottom-nav-left">
        <a href="/blog" class="blog-post__bottom-nav-link">
          ← Tous les articles
        </a>
      </div>
      
      <div class="blog-post__bottom-nav-right">
        Partagez cet article sur vos réseaux sociaux
      </div>
    </div>
  </nav>
</BlogLayout>

<style lang="scss">
@use '~/styles/variables' as *;
@use '~/styles/mixins' as *;

.blog-post {
  &__back-nav {
    margin-bottom: 1.5rem;
  }

  &__back-link {
    display: inline-flex;
    align-items: center;
    font-size: $text-sm;
    color: var(--text-muted);
    transition: color 0.2s ease;

    &:hover {
      color: var(--text-secondary);
    }
  }

  &__header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  &__category-wrapper {
    margin-bottom: 1rem;
  }

  &__category {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: $text-sm;
    font-weight: 500;
    background: #dbeafe;
    color: #1e40af;
  }

  &__title {
    font-size: $text-4xl;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  &__description {
    font-size: $text-xl;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  &__meta {
    display: flex;
    align-items: center;
    font-size: $text-sm;
    color: var(--text-muted);
    gap: 1.5rem;

    &-item {
      display: flex;
      align-items: center;
    }

    &-icon {
      margin-right: 0.25rem;
    }
  }

  &__tags-wrapper {
    margin-top: 1rem;
  }

  &__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  &__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    font-size: $text-xs;
    font-weight: 500;
    background: #f3f4f6;
    color: var(--text-secondary);
  }

  &__content {
    max-width: 100%;
    margin-bottom: 3rem;
  }

  &__related {
    border-top: 1px solid var(--border);
    padding-top: 2rem;

    &-title {
      font-size: $text-2xl;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }

    &-grid {
      display: grid;
      gap: 1.5rem;

      @include md {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      @include lg {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    &-card {
      background: white;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      transition: box-shadow 0.2s ease;

      &:hover {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      }

      &-content {
        margin-bottom: 0.75rem;
      }

      &-title {
        font-size: $text-lg;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
      }

      &-link {
        transition: color 0.2s ease;

        &:hover {
          color: #2563eb;
        }
      }

      &-date {
        font-size: $text-sm;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
      }

      &-desc {
        font-size: $text-sm;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      &-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      &-read-more {
        color: #2563eb;
        font-size: $text-sm;
        font-weight: 500;
        transition: color 0.2s ease;

        &:hover {
          color: #1e40af;
        }
      }
    }

    &-tag {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: 0.25rem;
      font-size: $text-xs;
      font-weight: 500;
      background: #f3f4f6;
      color: var(--text-secondary);
    }
  }

  &__bottom-nav {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    margin-top: 2rem;

    &-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    &-left,
    &-right {
      font-size: $text-sm;
      color: var(--text-muted);
    }

    &-link {
      transition: color 0.2s ease;

      &:hover {
        color: var(--text-secondary);
      }
    }
  }
}

/* Prose styling */
.prose {
  color: var(--text-primary);
  
  h1, h2, h3, h4 {
    color: var(--text-primary);
  }
  
  a {
    color: #2563eb;
    
    &:hover {
      color: #1e40af;
    }
  }
  
  code {
    background-color: #f3f4f6;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }
  
  pre {
    background-color: #111827;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }
  
  blockquote {
    border-left: 4px solid #3b82f6;
    padding-left: 1rem;
    font-style: italic;
    color: var(--text-secondary);
  }
}
</style>
