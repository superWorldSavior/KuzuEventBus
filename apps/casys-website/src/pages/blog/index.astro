---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

// Récupérer tous les articles de blog
const blogPosts = await getCollection('blog', ({ data }) => {
  return !data.draft; // Exclure les brouillons
});

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || 'Général';
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Articles en vedette
const featuredPosts = sortedPosts.filter(post => post.data.featured);
---

<BlogLayout title="Blog CASYS">
  <!-- En-tête du blog -->
  <div class="blog-index__header">
    <h1 class="blog-index__title">Blog CASYS</h1>
    <p class="blog-index__subtitle">
      Découvrez les dernières actualités, guides techniques et insights sur le développement de CASYS.
    </p>
  </div>

  <!-- Articles en vedette -->
  {featuredPosts.length > 0 && (
    <section class="blog-index__featured">
      <h2 class="blog-index__section-title">
        <span class="blog-index__section-icon">⭐</span>
        Articles en vedette
      </h2>
      <div class="blog-index__featured-grid">
        {featuredPosts.slice(0, 2).map((post) => (
          <article class="blog-index__featured-card">
            <div class="blog-index__card-meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('fr-FR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              {post.data.category && (
                <>
                  <span class="blog-index__card-meta-sep">•</span>
                  <span class="blog-index__card-meta-category">{post.data.category}</span>
                </>
              )}
            </div>
            <h3 class="blog-index__card-title">
              <a href={`/blog/${post.slug}`} class="blog-index__card-link">
                {post.data.title}
              </a>
            </h3>
            {post.data.description && (
              <p class="blog-index__card-desc">{post.data.description}</p>
            )}
            <div class="blog-index__card-footer">
              <div class="blog-index__card-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="blog-index__tag blog-index__tag--primary">
                    {tag}
                  </span>
                ))}
              </div>
              <a 
                href={`/blog/${post.slug}`} 
                class="blog-index__card-read-more"
              >
                Lire la suite →
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Articles par catégorie -->
  <section>
    <h2 class="blog-index__section-title">Tous les articles</h2>
    
    {Object.entries(postsByCategory).map(([category, posts]) => (
      <div class="blog-index__category">
        <h3 class="blog-index__category-title">
          <span class="blog-index__category-icon">📁</span>
          {category}
          <span class="blog-index__category-count">({posts.length})</span>
        </h3>
        
        <div class="blog-index__posts">
          {posts.map((post) => (
            <article class="blog-index__post-card">
              <div class="blog-index__post-card-inner">
                <div class="blog-index__post-card-content">
                  <h4 class="blog-index__post-title">
                    <a href={`/blog/${post.slug}`} class="blog-index__post-link">
                      {post.data.title}
                    </a>
                  </h4>
                  
                  <div class="blog-index__post-meta">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('fr-FR')}
                    </time>
                    <span class="blog-index__post-meta-sep">•</span>
                    <span>{post.data.author}</span>
                  </div>
                  
                  {post.data.description && (
                    <p class="blog-index__post-desc">{post.data.description}</p>
                  )}
                  
                  <div class="blog-index__post-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="blog-index__tag">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                
                <div class="blog-index__post-card-action">
                  <a 
                    href={`/blog/${post.slug}`}
                    class="blog-index__post-btn"
                  >
                    Lire
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</BlogLayout>

<style lang="scss">
@use '~/styles/variables' as *;
@use '~/styles/mixins' as *;

.blog-index {
  &__header {
    margin-bottom: 2rem;
  }

  &__title {
    font-size: $text-3xl;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  &__subtitle {
    font-size: $text-lg;
    color: var(--text-secondary);
  }

  &__featured {
    margin-bottom: 3rem;
  }

  &__section {
    &-title {
      font-size: $text-2xl;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
    }

    &-icon {
      color: #f59e0b;
      margin-right: 0.5rem;
    }
  }

  &__featured-grid {
    display: grid;
    gap: 1.5rem;

    @include md {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  &__featured-card {
    background: white;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    transition: box-shadow 0.2s ease;

    &:hover {
      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    }
  }

  &__card {
    &-meta {
      display: flex;
      align-items: center;
      font-size: $text-sm;
      color: var(--text-muted);
      margin-bottom: 0.75rem;

      &-sep {
        margin: 0 0.5rem;
      }

      &-category {
        color: #2563eb;
      }
    }

    &-title {
      font-size: $text-xl;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
    }

    &-link {
      transition: color 0.2s ease;

      &:hover {
        color: #2563eb;
      }
    }

    &-desc {
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    &-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    &-read-more {
      color: #2563eb;
      font-size: $text-sm;
      font-weight: 500;
      transition: color 0.2s ease;

      &:hover {
        color: #1e40af;
      }
    }
  }

  &__category {
    margin-bottom: 2rem;

    &-title {
      font-size: $text-lg;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
    }

    &-icon {
      color: #3b82f6;
      margin-right: 0.5rem;
    }

    &-count {
      margin-left: 0.5rem;
      font-size: $text-sm;
      color: var(--text-muted);
    }
  }

  &__posts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  &__post {
    &-card {
      background: white;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      transition: box-shadow 0.2s ease;

      &:hover {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      }

      &-inner {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
      }

      &-content {
        flex: 1;
      }

      &-action {
        margin-left: 1rem;
        flex-shrink: 0;
      }
    }

    &-title {
      font-size: $text-lg;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    &-link {
      transition: color 0.2s ease;

      &:hover {
        color: #2563eb;
      }
    }

    &-meta {
      display: flex;
      align-items: center;
      font-size: $text-sm;
      color: var(--text-muted);
      margin-bottom: 0.75rem;

      &-sep {
        margin: 0 0.5rem;
      }
    }

    &-desc {
      color: var(--text-secondary);
      font-size: $text-sm;
      margin-bottom: 0.75rem;
    }

    &-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }

    &-btn {
      display: inline-flex;
      align-items: center;
      padding: 0.375rem 0.75rem;
      border: 1px solid var(--border);
      font-size: $text-sm;
      font-weight: 500;
      border-radius: 0.375rem;
      color: var(--text-secondary);
      background: white;
      transition: all 0.2s ease;

      &:hover {
        background: #f9fafb;
      }
    }
  }

  &__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: $text-xs;
    font-weight: 500;
    background: #f3f4f6;
    color: var(--text-secondary);

    &--primary {
      background: #dbeafe;
      color: #1e40af;
    }
  }
}
</style>
