---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import I18n from '../features/i18n/I18n.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;

// Récupérer les articles de blog pour la navigation
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Articles récents (5 derniers)
const recentPosts = sortedPosts.slice(0, 5);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || 'Général';
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Tags populaires
const allTags = sortedPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const popularTags = Object.entries(tagCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 10)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Blog CASYS - Articles et actualités" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen overflow-hidden">
    <!-- Nav bar de l'application -->
    <nav class="bg-white border-b border-gray-200 px-4 py-3">
      <div class="flex items-center justify-between">
        <!-- Logo et titre -->
        <div class="flex items-center space-x-4">
          <div class="flex items-center">
            <img src="/icons/favicon-32x32.png" alt="CASYS" class="w-8 h-8 mr-2" />
            <h1 class="text-xl font-bold text-gray-900">CASYS</h1>
            <span class="ml-2 text-sm text-gray-500">Blog</span>
          </div>
        </div>
        
        <!-- Navigation -->
        <div class="flex items-center space-x-6">
          <a 
            href="/blog" 
            class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
          >
            Blog
          </a>
          
          <!-- Séparateur -->
          <div class="h-6 w-px bg-gray-300"></div>
          
          <!-- Bouton retour landing -->
          <a 
            href="/" 
            class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
          >
            ← Accueil
          </a>
        </div>
      </div>
    </nav>
    
    <!-- Contenu principal avec nav bar -->
    <div class="flex" style="height: calc(100vh - 60px);">
      <!-- Sidebar de navigation blog -->
      <aside class="w-80 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">📝 Blog CASYS</h2>
          <p class="text-sm text-gray-500">
            Articles et actualités sur le développement
          </p>
        </div>
        
        <!-- Navigation du blog -->
        <nav class="flex-1 overflow-y-auto p-4 space-y-6">
          <!-- Lien vers l'index -->
          <div>
            <a 
              href="/blog" 
              class={`block py-2 px-3 rounded-md font-medium transition-colors ${
                currentPath === '/blog' || currentPath === '/blog/'
                  ? 'bg-blue-50 text-blue-700 border-l-2 border-blue-500'
                  : 'text-gray-900 hover:bg-gray-50'
              }`}
            >
              🏠 Tous les articles
            </a>
          </div>
          
          <!-- Articles récents -->
          <div>
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 py-2">
              📅 Articles récents
            </h3>
            <ul class="space-y-1">
              {recentPosts.map((post) => (
                <li>
                  <a 
                    href={`/blog/${post.slug}`}
                    class={`block py-2 px-3 rounded-md text-sm transition-colors ${
                      currentPath === `/blog/${post.slug}`
                        ? 'bg-blue-50 text-blue-700 border-l-2 border-blue-500'
                        : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900'
                    }`}
                  >
                    <div class="truncate font-medium">{post.data.title}</div>
                    <div class="text-xs text-gray-500 mt-1 flex items-center">
                      <span>{post.data.date.toLocaleDateString('fr-FR')}</span>
                      {post.data.category && (
                        <>
                          <span class="mx-1">•</span>
                          <span>{post.data.category}</span>
                        </>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Catégories -->
          <div>
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 py-2">
              📁 Par catégorie
            </h3>
            <ul class="space-y-1">
              {Object.entries(postsByCategory).map(([categoryName, posts]) => (
                <li>
                  <div class="py-1 px-3 text-sm font-medium text-gray-900 flex items-center justify-between">
                    <span>{categoryName}</span>
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
                      {posts.length}
                    </span>
                  </div>
                  <ul class="ml-3 space-y-1">
                    {posts.slice(0, 3).map((post) => (
                      <li>
                        <a 
                          href={`/blog/${post.slug}`}
                          class={`block py-1 px-2 rounded text-xs transition-colors ${
                            currentPath === `/blog/${post.slug}`
                              ? 'bg-blue-50 text-blue-700'
                              : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
                          }`}
                        >
                          <div class="truncate">{post.data.title}</div>
                        </a>
                      </li>
                    ))}
                    {posts.length > 3 && (
                      <li>
                        <span class="block py-1 px-2 text-xs text-gray-400">
                          +{posts.length - 3} autres
                        </span>
                      </li>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Tags populaires -->
          <div>
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 py-2">
              🏷️ Tags populaires
            </h3>
            <div class="px-3">
              <div class="flex flex-wrap gap-1">
                {popularTags.map((tag) => (
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer transition-colors">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="border-t border-gray-200 pt-4">
            <div class="px-3 space-y-2">
              <button class="w-full text-left py-2 px-3 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors">
                🔍 Rechercher
              </button>
              <button class="w-full text-left py-2 px-3 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors">
                📧 S'abonner aux nouveautés
              </button>
            </div>
          </div>
        </nav>
      </aside>

      <!-- Contenu principal -->
      <main class="flex-1 overflow-y-auto">
        <div class="max-w-4xl mx-auto p-8">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
