# Environment Configuration
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://kuzu_user:kuzu_password@localhost:5433/kuzu_eventbus
REDIS_URL=redis://localhost:6380/0
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
KUZU_DATA_DIR=./.kuzu_data
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8200

# JWT (SSE tokens)
# Generate a strong secret (choose ONE and paste the output below):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=kuzu-event-bus
JWT_AUDIENCE=kuzu-event-bus-clients
JWT_TTL_SECONDS=300

# Application Configuration
APP_NAME=Kuzu Event Bus
APP_VERSION=0.1.0
DEBUG=true

# MinIO Buckets
KUZU_DB_BUCKET=kuzu-databases
BACKUP_BUCKET=kuzu-backups

# Redis Configuration
REDIS_STREAM_KEY=kuzu_transactions
REDIS_CONSUMER_GROUP=kuzu_processors

# File Upload Limits
MAX_FILE_SIZE_MB=100
ALLOWED_DB_EXTENSIONS=.kuzu

# Transaction Configuration
TRANSACTION_TIMEOUT_SECONDS=300
MAX_CONCURRENT_TRANSACTIONS=10