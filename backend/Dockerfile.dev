# Development Dockerfile for KuzuEventBus Backend with Hot Reload
FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    # Enable Python to detect file changes
    PYTHONDONTUSESITECUSTOMIZE=1

# System deps (psycopg2 and others may need headers)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies first (for better Docker layer caching)
COPY pyproject.toml requirements.txt ./
RUN python -m pip install -U pip

# Install development dependencies including watchfiles for hot reload
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Install additional development tools for hot reload
RUN pip install \
    watchfiles \
    uvicorn[standard] \
    python-dotenv

# Copy the entire backend source code
COPY . .

# Install backend package in development mode
RUN pip install -e .[dev]

# Ensure Python can import src/* modules
ENV PYTHONPATH=/app

# Create non-root user for security (optional, but good practice)
RUN groupadd -r appuser && useradd -r -g appuser appuser
RUN chown -R appuser:appuser /app
USER appuser

# Expose port
EXPOSE 8000

# Default command with hot reload enabled
# This can be overridden in docker-compose.dev.yml
CMD ["uvicorn", "src.presentation.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/src", "--reload-delay", "0.25", "--log-level", "info"]