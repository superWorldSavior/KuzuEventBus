---
import I18n from '../i18n/I18n.astro';
---

<section id="branching" class="py-20 relative" style="background: var(--bg-main);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold" style="color: var(--text-primary);">
        <I18n>
          <Fragment slot="en">Branching & Time Travel</Fragment>
          <Fragment slot="fr">Branches & Voyage dans le Temps</Fragment>
        </I18n>
      </h2>
      <p class="mt-4 text-xl" style="color: var(--text-secondary);">
        <I18n>
          <Fragment slot="en">Point-in-Time Recovery and Git-like branches for your graph data</Fragment>
          <Fragment slot="fr">Point-in-Time Recovery et branches Git-like pour vos données graphe</Fragment>
        </I18n>
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Visualization -->
      <div>
        
        
        <!-- Git-like Branch Diagram (Mermaid, responsive) -->
        <div class="w-full overflow-x-auto">
          <div id="branch-graph" class="min-w-[360px] p-4 mx-auto max-w-full h-[320px] lg:h-[360px] overflow-auto"></div>
        </div>
        <script is:inline>
          (async () => {
            try {
              const mermaid = window.mermaid || (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
              if (!window.mermaid) window.mermaid = mermaid;
              mermaid.initialize({ 
                startOnLoad: false, 
                securityLevel: 'loose', 
                theme: 'forest',
                themeVariables: {
                  primaryColor: '#f3e8ff',             // subtle violet tint
                  primaryTextColor: '#1f2937',         // gray-800
                  primaryBorderColor: '#7C4BB2',       // violet border
                  lineColor: '#7C4BB2',                // main line violet
                  textColor: '#1f2937',
                  tertiaryColor: '#e9d5ff',            // light violet
                  fontSize: '12px',
                  fontFamily: 'ui-sans-serif, system-ui, sans-serif'
                }
              });

              // BT: bottom-to-top so timeline goes upward
              // Git wording: branch created from c2 (recovery), feature dev merged into main, HEAD on latest commit.
              const graph = `gitGraph BT:\n  %% Historique initial de main\n  commit id: "c1"\n  commit id: "c2" tag: "r1"\n\n  %% PITR: recovery depuis c2 (r1)\n  branch recovery\n  checkout recovery\n  commit id: "r2"\n\n  %% main continue -> c3\n  checkout main\n  commit id: "c3"\n\n  %% dev part de c3\n  branch dev\n  checkout dev\n  commit id: "e1" tag: "e1"\n  commit id: "d2"\n\n  %% merge dev -> main\n  checkout main\n  merge dev\n\n  %% promotion: recovery (r1) devient la base de main\n  merge recovery tag: "promote r1"\n\n  %% HEAD final\n  commit id: "c4" tag: "HEAD"`;

              const { svg } = await mermaid.render('branch-graph-svg', graph);
              const el = document.getElementById('branch-graph');
              if (el) {
                el.innerHTML = svg;
                const svgEl = el.querySelector('svg');
                if (svgEl) {
                  svgEl.style.maxWidth = '100%';
                  svgEl.style.height = '100%';
                }
                // Synchroniser la hauteur du diagramme avec la colonne droite
                const right = document.getElementById('branch-right-col');
                const sync = () => {
                  if (!right) return;
                  const h = right.getBoundingClientRect().height;
                  if (h > 0) {
                    el.style.height = `${h}px`;
                  }
                };
                sync();
                if (window.ResizeObserver && right) {
                  const ro = new ResizeObserver(() => sync());
                  ro.observe(right);
                }
                window.addEventListener('resize', sync);
              }
            } catch (e) { console.error('Mermaid render failed', e); }
          })();
        </script>
      </div>

      <!-- Right: Code Examples with Tabs -->
      <div id="branch-right-col">
        <!-- Tabs -->
        <div class="flex gap-2 mb-6 flex-wrap">
          <button class="branch-tab active px-6 py-3 rounded-lg font-semibold" data-tab="branch">
            <I18n>
              <Fragment slot="en">Create Branches</Fragment>
              <Fragment slot="fr">Créer des Branches</Fragment>
            </I18n>
          </button>
          <button class="branch-tab px-6 py-3 rounded-lg font-semibold" data-tab="pitr">
            <I18n>
              <Fragment slot="en">PITR</Fragment>
              <Fragment slot="fr">PITR</Fragment>
            </I18n>
          </button>
          <button class="branch-tab px-6 py-3 rounded-lg font-semibold" data-tab="snapshot">
            <I18n>
              <Fragment slot="en">Snapshots</Fragment>
              <Fragment slot="fr">Snapshots</Fragment>
            </I18n>
          </button>
        </div>

        <!-- Code blocks -->
        <div class="branch-content-wrapper">
          <!-- Create Branches -->
          <div class="branch-content active" data-content="branch">
            <pre class="code-block"><code class="language-python"><span class="comment"># Créer une branche depuis main</span>
<span class="keyword">import</span> casys_db

engine = casys_db.CasysEngine(data_dir=<span class="string">"~/.casys_db"</span>)
db = engine.open_database(<span class="string">"social"</span>)

<span class="comment"># Créer une branche "main" si elle n'existe pas</span>
engine.create_branch(<span class="string">"social"</span>, <span class="string">"main"</span>)

<span class="comment"># Créer une branche expérimentale depuis main</span>
engine.create_branch(<span class="string">"social"</span>, <span class="string">"experiment"</span>)

<span class="comment"># Travailler sur experiment sans affecter main</span>
exp_branch = engine.open_branch(<span class="string">"social"</span>, <span class="string">"experiment"</span>)
result = exp_branch.query(<span class="string">"""
  CREATE (p:Person {'{'} name: 'Test User' {'}'})
  RETURN p
"""</span>)

<span class="comment"># main reste inchangé !</span>
</code></pre>
          </div>

          <!-- PITR -->
          <div class="branch-content" data-content="pitr">
            <pre class="code-block"><code class="language-python"><span class="comment"># Point-in-Time Recovery</span>
<span class="keyword">from</span> casys_db <span class="keyword">import</span> Database

db = Database(<span class="string">"social.db"</span>)

<span class="comment"># Voir l'historique des modifications</span>
history = db.history(from_time=<span class="string">"yesterday"</span>)
<span class="keyword">for</span> event <span class="keyword">in</span> history:
    <span class="function">print</span>(f<span class="string">"{'{'} event.timestamp {'}'}: {'{'} event.type {'}'}"</span>)

<span class="comment"># Créer une branche depuis un point dans le passé</span>
recovery = db.branch_at(
    name=<span class="string">"recovery"</span>,
    timestamp=<span class="string">"2 hours ago"</span>
)

<span class="comment"># Explorer cet état passé (lecture seule)</span>
result = recovery.query(<span class="string">"MATCH (u:User) RETURN count(u)"</span>)
<span class="function">print</span>(f<span class="string">"Utilisateurs à ce moment: {'{'} result {'}'}"</span>)
</code></pre>
          </div>

          <!-- Snapshots -->
          <div class="branch-content" data-content="snapshot">
            <pre class="code-block"><code class="language-python"><span class="comment"># Snapshots et persistence</span>
<span class="keyword">import</span> casys_db

engine = casys_db.CasysEngine(data_dir=<span class="string">"~/.casys_db"</span>)
db = engine.open_database(<span class="string">"social"</span>)
branch = engine.open_branch(<span class="string">"social"</span>, <span class="string">"main"</span>)

<span class="comment"># Créer des données</span>
branch.query(<span class="string">"""
  CREATE (u:User {'{'} name: 'Alice', age: 30 {'}'})
"""</span>)

<span class="comment"># Persister les changements sur disque</span>
branch.flush()  <span class="comment"># → Write segments + WAL</span>

<span class="comment"># Créer un snapshot explicite</span>
timestamp = engine.snapshot(branch, <span class="keyword">None</span>)
<span class="function">print</span>(f<span class="string">"Snapshot créé: {'{'} timestamp {'}'}"</span>)

<span class="comment"># Recharger depuis le disque</span>
branch.load()
</code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid md:grid-cols-3 gap-6 mt-16">
      <div class="text-center p-6 rounded-xl flat-card">
        <div class="text-4xl mb-3">🌳</div>
        <h3 class="font-bold text-lg mb-2" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Isolated Branches</Fragment>
            <Fragment slot="fr">Branches Isolées</Fragment>
          </I18n>
        </h3>
        <p class="text-sm" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Test changes safely. Each branch is completely isolated.</Fragment>
            <Fragment slot="fr">Testez des changements sans risque. Chaque branche est complètement isolée.</Fragment>
          </I18n>
        </p>
      </div>

      <div class="text-center p-6 rounded-xl flat-card">
        <div class="text-4xl mb-3">⏰</div>
        <h3 class="font-bold text-lg mb-2" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Time Travel</Fragment>
            <Fragment slot="fr">Voyage dans le Temps</Fragment>
          </I18n>
        </h3>
        <p class="text-sm" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Create a branch from any past commit. Debug easily.</Fragment>
            <Fragment slot="fr">Créez une branche depuis n'importe quel commit passé. Débugguez facilement.</Fragment>
          </I18n>
        </p>
      </div>

      <div class="text-center p-6 rounded-xl flat-card">
        <div class="text-4xl mb-3">📸</div>
        <h3 class="font-bold text-lg mb-2" style="color: var(--text-primary);">
          <I18n>
            <Fragment slot="en">Auto Snapshots</Fragment>
            <Fragment slot="fr">Snapshots Auto</Fragment>
          </I18n>
        </h3>
        <p class="text-sm" style="color: var(--text-secondary);">
          <I18n>
            <Fragment slot="en">Each commit = snapshot. No data loss, complete history.</Fragment>
            <Fragment slot="fr">Chaque commit = snapshot. Aucune perte de données, historique complet.</Fragment>
          </I18n>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
.branch-tab {
  background: var(--card-bg);
  border: 1px solid var(--border);
  color: var(--text-secondary);
}

.branch-tab.active {
  background: var(--acc-soft);
  color: var(--text-primary);
  border-color: var(--acc);
}

.code-block {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 0.5rem;
  padding: 1.5rem;
  overflow-x: auto;
  font-family: 'Fira Code', 'JetBrains Mono', monospace;
  font-size: 0.9rem;
  line-height: 1.6;
}

.branch-content {
  display: none;
}

.branch-content.active {
  display: block;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Syntax highlighting */
.keyword { color: #c678dd; font-weight: 600; }
.string { color: #98c379; }
.comment { color: #5c6370; font-style: italic; }
.function { color: #61afef; }
.type { color: #e5c07b; }
.number { color: #d19a66; }

/* Flat card */
.flat-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
}
</style>

<script>
document.querySelectorAll('.branch-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const targetTab = tab.getAttribute('data-tab');
    
    // Update tabs
    document.querySelectorAll('.branch-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    
    // Update content
    document.querySelectorAll('.branch-content').forEach(c => c.classList.remove('active'));
    document.querySelector(`[data-content="${targetTab}"]`)?.classList.add('active');
  });
});
</script>
