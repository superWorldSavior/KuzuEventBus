<style>
/* Client carousel fixed en bas de page */
.client-results-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 120px;
  overflow: hidden;
  z-index: 40;
  backdrop-filter: blur(10px);
  background: rgba(255, 255, 255, 0.05);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.client-results-carousel {
  display: flex;
  gap: 1.5rem;
  padding: 1rem;
  overflow: hidden;
  white-space: nowrap;
  position: relative;
  width: max-content;
  height: 100%;
  align-items: center;
}

.scroll-right {
  animation: scrollRight 40s linear infinite;
}

@keyframes scrollRight {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.client-card {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(8px);
  border-radius: 12px;
  padding: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.2);
  width: 240px;
  height: 100px;
  flex-shrink: 0;
  transition: transform 0.3s ease, background 0.3s ease;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.client-card:hover {
  transform: translateY(-4px) scale(1.02);
  background: rgba(255, 255, 255, 0.15);
}

.client-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, #000, #dbbddb);
}

.client-header {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.client-logo {
  font-size: 0.9rem;
  font-weight: 700;
  background: linear-gradient(90deg, #000, #dbbddb);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.client-domain {
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.6);
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', monospace;
}

.client-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.stat {
  text-align: center;
}

.stat-value {
  font-size: 1rem;
  font-weight: 800;
  background: linear-gradient(90deg, #000, #dbbddb);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1;
}

.stat-label {
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-top: 0.1rem;
}

/* Mobile responsive */
@media (max-width: 768px) {
  .client-results-fixed {
    height: 100px;
  }
  
  .client-card {
    width: 200px;
    height: 80px;
    padding: 0.75rem;
  }
  
  .client-logo {
    font-size: 0.8rem;
  }
  
  .client-domain {
    font-size: 0.65rem;
  }
  
  .stat-value {
    font-size: 0.9rem;
  }
  
  .stat-label {
    font-size: 0.6rem;
  }
  
  .client-results-carousel {
    gap: 1rem;
    padding: 0.5rem;
  }
}

@media (max-width: 480px) {
  .client-results-fixed {
    height: 80px;
  }
  
  .client-card {
    width: 160px;
    height: 60px;
    padding: 0.5rem;
  }
  
  .client-stats {
    gap: 0.5rem;
  }
  
  .stat-value {
    font-size: 0.8rem;
  }
  
  .stat-label {
    font-size: 0.55rem;
  }
}

/* Dark mode adjustments */
@media (prefers-color-scheme: dark) {
  .client-results-fixed {
    background: rgba(0, 0, 0, 0.3);
    border-top-color: rgba(219, 189, 219, 0.2);
  }
  
  .client-card::before {
    background: linear-gradient(90deg, #dbbddb, #ffffff);
  }
  
  .client-logo {
    background: linear-gradient(90deg, #dbbddb, #ffffff);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .stat-value {
    background: linear-gradient(90deg, #dbbddb, #ffffff);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
}

/* Pause animation on hover */
.client-results-fixed:hover .client-results-carousel {
  animation-play-state: paused;
}

/* Box shadow pour effet glassmorphism */
.client-card {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

.client-card:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}
</style>
