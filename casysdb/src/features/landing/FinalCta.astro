---
const locale = (Astro as any).currentLocale ?? 'en';
const t = locale === 'fr'
  ? {
      title: 'Prêt à commencer ?',
      sub: "CasysDB est open-source et prêt à l'emploi. Consultez la documentation ou le code source.",
      btnDoc: 'Documentation',
      btnGithub: 'Voir sur GitHub',
    }
  : {
      title: 'Ready to Get Started?',
      sub: 'CasysDB is open-source and ready to use. Check out the documentation or source code.',
      btnDoc: 'Documentation',
      btnGithub: 'View on GitHub',
    };
---

<section id="cta" class="py-20 relative overflow-hidden isolate z-[60]" style="background: transparent;">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">{t.title}</h2>
    <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-300">{t.sub}</p>

    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/getting-started/installation/"
        class="brutal-btn brutal-btn-primary text-center">
        {t.btnDoc}
      </a>
      <a
        href="https://github.com/casysai/casysdb"
        target="_blank"
        rel="noopener noreferrer"
        class="brutal-btn brutal-btn-secondary text-center">
        <span class="flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          {t.btnGithub}
        </span>
      </a>
    </div>
  </div>
</section>

<style>
/* Brutalist Buttons */
.brutal-btn {
  padding: 1rem 2rem;
  border-radius: 12px;
  font-weight: 600;
  border: 3px solid #000;
  box-shadow: 5px 5px 0 #9f7aea;
  transition: all 0.2s;
  text-decoration: none;
  display: inline-block;
}

.brutal-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 3px 3px 0 #9f7aea;
}

.brutal-btn-primary {
  background: linear-gradient(135deg, #5B2E7E, #6C3A94);
  color: white;
}

.brutal-btn-secondary {
  background: var(--surface);
  color: var(--text-primary);
}

:global(.dark) .brutal-btn {
  border-color: #fff;
  box-shadow: 5px 5px 0 #7C4BB2;
}

:global(.dark) .brutal-btn:hover {
  box-shadow: 3px 3px 0 #7C4BB2;
}
</style>
