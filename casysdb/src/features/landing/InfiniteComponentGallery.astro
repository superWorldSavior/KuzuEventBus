<style>
/* Galerie de composants avec défilement infini */
.component-gallery-wrapper {
  position: relative;
  width: 100vw;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  margin-top: 2rem;
  padding: 1rem 0;
  overflow: hidden;
  opacity: 0.95;
}

.component-row {
  display: flex;
  gap: 2rem;
  padding: 1rem 0;
  overflow: hidden;
  white-space: nowrap;
  position: relative;
  width: max-content;
}

.scroll-right {
  animation: scrollRight 60s linear infinite;
}

.scroll-left {
  animation: scrollLeft 60s linear infinite;
}

@keyframes scrollRight {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

@keyframes scrollLeft {
  0% {
    transform: translateX(-50%);
  }
  100% {
    transform: translateX(0);
  }
}

.component-card {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 12px;
  padding: 0.6rem;
  text-align: center;
  transition: transform 0.3s ease, background 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.2);
  width: 100px;
  height: 100px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  position: relative;
}

.component-card .icon-container {
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-shrink: 0;
}

.component-card:hover {
  transform: translateY(-5px);
  background: rgba(255, 255, 255, 0.2);
}

/* Cartes spécialisées par catégorie */
.media-card {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
}

.search-card {
  background: rgba(34, 197, 94, 0.15);
  border: 1px solid rgba(34, 197, 94, 0.3);
}

.audio-card {
  background: rgba(139, 92, 246, 0.15);
  border: 1px solid rgba(139, 92, 246, 0.3);
}

.writing-card {
  background: rgba(59, 130, 246, 0.15);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.map-card {
  background: rgba(34, 197, 94, 0.15);
  border: 1px solid rgba(34, 197, 94, 0.3);
}

.social-card {
  background: rgba(236, 72, 153, 0.15);
  border: 1px solid rgba(236, 72, 153, 0.3);
}

.forms-card {
  background: rgba(245, 158, 11, 0.15);
  border: 1px solid rgba(245, 158, 11, 0.3);
}

.component-label {
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  line-height: 1.1;
  margin-top: auto;
  text-align: center;
  width: 100%;
}

/* Icônes et visualisations - Tailles standardisées */
.mini-chart {
  display: flex;
  align-items: end;
  justify-content: center;
  gap: 2px;
  height: 30px;
  width: 40px;
}

.chart-bar {
  width: 6px;
  background: linear-gradient(to top, #8b5a87, #a67c9a);
  border-radius: 2px;
  animation: chartPulse 2s ease-in-out infinite;
}

@keyframes chartPulse {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

/* Icônes emoji standardisées */
.video-icon, .image-icon, .search-icon, .social-icon, .form-icon, .calendar-icon, .map-icon, .writing-icon, .pdf-icon, .newsletter-icon, .certification-icon, .ai-icon, .share-icon {
  font-size: 1.8rem;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* Conteneurs d'icônes complexes */
