---
// Galerie infinie massive avec tous types de composants web possibles
---

<div class="component-gallery-wrapper">
  <!-- Ligne 1 - Charts & Analytics -->
  <div class="component-row scroll-left">
    <div class="component-card">
      <div class="icon-container">
        <div class="mini-chart">
          <div class="chart-bar" style="height: 60%"></div>
          <div class="chart-bar" style="height: 80%"></div>
          <div class="chart-bar" style="height: 45%"></div>
          <div class="chart-bar" style="height: 70%"></div>
        </div>
      </div>
      <span class="component-label">Bar Charts</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="line-chart">
          <svg viewBox="0 0 60 40" class="mini-svg">
            <polyline points="5,35 15,25 25,30 35,15 45,20 55,10" stroke="#8b5a87" stroke-width="2" fill="none"/>
          </svg>
        </div>
      </div>
      <span class="component-label">Line Charts</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="pie-chart-mini">
          <div class="pie-slice" style="--color: #8b5a87; --angle: 120deg;"></div>
          <div class="pie-slice" style="--color: #2d1b69; --angle: 240deg;"></div>
        </div>
      </div>
      <span class="component-label">Pie Charts</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="scatter-chart">
          <div class="scatter-dot" style="left: 20%; top: 30%;"></div>
          <div class="scatter-dot" style="left: 40%; top: 60%;"></div>
          <div class="scatter-dot" style="left: 70%; top: 20%;"></div>
          <div class="scatter-dot" style="left: 80%; top: 70%;"></div>
        </div>
      </div>
      <span class="component-label">Scatter Plot</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="heatmap-mini">
          <div class="heat-cell" style="--intensity: 0.8;"></div>
          <div class="heat-cell" style="--intensity: 0.3;"></div>
          <div class="heat-cell" style="--intensity: 0.9;"></div>
          <div class="heat-cell" style="--intensity: 0.5;"></div>
        </div>
      </div>
      <span class="component-label">Heatmaps</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="radar-chart">
          <svg viewBox="0 0 60 60" class="mini-svg">
            <polygon points="30,5 50,20 45,45 15,45 10,20" stroke="#8b5a87" stroke-width="1.5" fill="rgba(139,90,135,0.2)"/>
          </svg>
        </div>
      </div>
      <span class="component-label">Radar Charts</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="gauge-mini">
          <div class="gauge-arc"></div>
          <div class="gauge-needle"></div>
        </div>
      </div>
      <span class="component-label">Gauges</span>
    </div>
    
    <div class="component-card">
      <div class="icon-container">
        <div class="treemap-mini">
          <div class="tree-rect" style="width: 40%; height: 60%; background: #8b5a87;"></div>
          <div class="tree-rect" style="width: 35%; height: 40%; background: #2d1b69;"></div>
