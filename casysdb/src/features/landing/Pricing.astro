---
const locale = (Astro as any).currentLocale ?? 'fr';

const t = locale === 'fr'
  ? {
      title: 'Tarifs & Fonctionnalités',
      subtitle: 'Accès anticipé — Ce qui est disponible maintenant',
      starterTitle: 'Starter — Tout inclus',
      starterPrice: '119 €',
      starterPeriod: ' / mois',
      starterDesc: 'Toutes les fonctionnalités disponibles incluses',
      comingSoonTitle: 'Bientôt disponible',
      cta: 'Rejoindre la liste d\'attente',
      available: [
        { name: 'CMS auto-publié', desc: 'Publication automatique GitHub Pages' },
        { name: 'Posts sociaux automatiques', desc: 'LinkedIn, X (Twitter) et autres' },
        { name: 'Liens internes SEO', desc: 'Maillage interne optimisé automatiquement' },
        { name: 'Audit SEO complet', desc: 'Analyse et optimisation du contenu' },
        { name: 'Editorial gap', desc: 'Idées d\'articles manquants vs concurrence' },
        { name: 'Génération multi-format', desc: 'Articles, guides, tutoriels' },
      ],
      comingSoon: [
        { name: 'Newsletter automatique', desc: 'Substack, Mailchimp, Brevo' },
        { name: 'Validation workflow', desc: 'Approbation avant publication' },
        { name: 'Reporting avancé', desc: 'Analytics et insights mensuels' },
        { name: 'Garde-fous marque', desc: 'Ton, glossaire, termes interdits' },
        { name: 'Mises à jour auto', desc: 'Refresh automatique du contenu' },
        { name: 'WordPress, Lovable', desc: 'Intégrations CMS additionnelles' },
      ],
      betaNote: 'Prix de lancement pour les premiers utilisateurs',
    }
  : {
      title: 'Pricing & Features',
      subtitle: 'Early Access — What\'s available now',
      starterTitle: 'Starter — All Included',
      starterPrice: '$129',
      starterPeriod: ' / month',
      starterDesc: 'All available features included',
      comingSoonTitle: 'Coming soon',
      cta: 'Join the waitlist',
      available: [
        { name: 'CMS auto-publish', desc: 'Automatic GitHub Pages publishing' },
        { name: 'Auto social posts', desc: 'LinkedIn, X (Twitter) and more' },
        { name: 'Internal SEO links', desc: 'Automated internal linking optimization' },
        { name: 'Full SEO audit', desc: 'Content analysis and optimization' },
        { name: 'Editorial gap analysis', desc: 'Missing topics vs competition' },
        { name: 'Multi-format generation', desc: 'Articles, guides, tutorials' },
      ],
      comingSoon: [
        { name: 'Auto newsletter', desc: 'Substack, Mailchimp, Brevo' },
        { name: 'Approval workflow', desc: 'Review before publishing' },
        { name: 'Advanced reporting', desc: 'Monthly analytics and insights' },
        { name: 'Brand guardrails', desc: 'Tone, glossary, forbidden terms' },
        { name: 'Auto refresh', desc: 'Automatic content updates' },
        { name: 'WordPress, Lovable', desc: 'Additional CMS integrations' },
      ],
      betaNote: 'Launch pricing for early adopters',
    };
---

<section id="pricing" class="py-20 relative overflow-hidden" style="background: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight" style="color: var(--text-primary);">{t.title}</h2>
      <p class="mt-3 text-lg" style="color: var(--text-secondary);">{t.subtitle}</p>
    </div>

    <!-- Price display -->
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">{t.starterTitle}</h3>
      <div class="flex items-baseline justify-center gap-1 mb-2">
        <span class="text-5xl font-extrabold bg-clip-text text-transparent bg-[linear-gradient(90deg,#000,#dbbddb)] dark:bg-[linear-gradient(90deg,#dbbddb,#ffffff)]">{t.starterPrice}</span>
        <span class="text-xl" style="color: var(--text-secondary);">{t.starterPeriod}</span>
      </div>
      <p class="text-lg" style="color: var(--text-secondary);">{t.starterDesc}</p>
    </div>

    <!-- Features cards -->
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Available features card -->
      <div class="relative rounded-2xl p-8 transition hover:-translate-y-1.5 hover:shadow-xl" style="background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: 0 4px 15px var(--card-shadow);">
        <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl bg-[linear-gradient(90deg,#000,#dbbddb)]"></div>

        <h4 class="text-lg font-semibold mb-6" style="color: var(--text-primary);">
          ✅ Inclus maintenant
        </h4>
        <ul class="space-y-4">
          {t.available.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium" style="color: var(--text-primary);">{item.name}</p>
                <p class="text-sm mt-0.5" style="color: var(--text-secondary);">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coming soon features card -->
      <div class="relative rounded-2xl p-8 transition hover:-translate-y-1.5 hover:shadow-xl opacity-75" style="background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: 0 4px 15px var(--card-shadow);">
        <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl bg-gradient-to-r from-gray-400 to-gray-600"></div>

        <h4 class="text-lg font-semibold mb-6" style="color: var(--text-primary);">
          ⏳ {t.comingSoonTitle}
        </h4>
        <ul class="space-y-4">
          {t.comingSoon.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium" style="color: var(--text-primary);">{item.name}</p>
                <p class="text-sm mt-0.5" style="color: var(--text-secondary);">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-base mb-6" style="color: var(--text-secondary);">{t.betaNote}</p>
      <a href="#cta" class="inline-flex items-center justify-center px-8 py-4 rounded-lg text-white font-semibold shadow-md transition hover:shadow-lg hover:scale-105 bg-[linear-gradient(90deg,#000,#dbbddb)] focus:outline-none focus:ring-2 focus:ring-white/50 dark:focus:ring-white/30">
        {t.cta}
      </a>
    </div>
  </div>
</section>
