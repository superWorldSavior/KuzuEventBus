---
const locale = (Astro as any).currentLocale ?? 'en';
const t = locale === 'fr'
  ? {
      h2: 'Votre stratégie de contenu est inefficace',
      sub: 'Vous perdez des heures et ratez des opportunités face aux concurrents.',
      without: 'Sans Casys',
      with: 'Avec Casys',
      w1: '5 à 10 heures par article et par plateforme',
      w2: 'Difficile de cibler les bons mots‑clés et de suivre les tendances',
      w3: 'Contenu vite obsolète, coûts élevés',
      w4: 'Verrouillage éditeur/CMS et workflows manuels',
      s1: 'Un mois d’articles en 60 minutes',
      s2: 'Optimisation continue sans travail manuel',
      s3: 'Positionnements plus rapides sur les requêtes ciblées',
      s4: 'Fichiers statiques, liberté totale de plateforme',
    }
  : {
      h2: 'Your Content Strategy is Broken',
      sub: 'You waste hours and miss opportunities vs. competitors.',
      without: 'Without Casys',
      with: 'With Casys',
      w1: '5–10 hours per article and per platform',
      w2: 'Hard to target the right keywords and follow trends',
      w3: 'Content gets outdated quickly, high costs',
      w4: 'CMS lock‑in and manual workflows',
      s1: 'A month of content in 60 minutes',
      s2: 'Continuous optimization without manual work',
      s3: 'Faster rankings on targeted queries',
      s4: 'Static files you own — zero lock‑in',
    };
---

<section id="problem" class="pt-8 pb-20 sm:pt-12 sm:pb-24 relative overflow-hidden" style="background: transparent; color: var(--text-primary);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight" style="color: var(--text-primary);">{t.h2}</h2>
      <p class="mt-4 text-lg" style="color: var(--text-secondary);">{t.sub}</p>
    </div>

    <div class="mt-16 max-w-5xl mx-auto grid md:grid-cols-2 gap-6 lg:gap-8">
      <!-- Problem Card -->
      <div class="relative rounded-2xl p-8 backdrop-blur-md" style="background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: 0 10px 25px var(--card-shadow);">
        <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: var(--accent-problem);"></div>
        <h3 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">{t.without}</h3>
        <ul class="space-y-3 text-base" style="color: var(--text-secondary);">
          <li class="flex items-start gap-2">
            <span class="text-red-500 mt-1">×</span>
            <span>{t.w1}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-500 mt-1">×</span>
            <span>{t.w2}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-500 mt-1">×</span>
            <span>{t.w3}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-500 mt-1">×</span>
            <span>{t.w4}</span>
          </li>
        </ul>
      </div>

      <!-- Solution Card -->
      <div class="relative rounded-2xl p-8 backdrop-blur-md" style="background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: 0 10px 25px var(--card-shadow);">
        <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: var(--accent-solution);"></div>
        <h3 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">{t.with}</h3>
        <ul class="space-y-3 text-base" style="color: var(--text-secondary);">
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>{t.s1}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>{t.s2}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>{t.s3}</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-1">✓</span>
            <span>{t.s4}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
