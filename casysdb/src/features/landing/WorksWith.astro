---
const locale = (Astro as any).currentLocale ?? 'en';
const t = locale === 'fr'
  ? {
      title: 'Fonctionne avec tout ce que vous utilisez',
      subtitle: 'CMS, outils statiques et plateformes sociales',
      items: [
        { name: 'GitHub', slug: 'github', color: '000000' },
        { name: 'Lovable', slug: 'lovable', color: 'FF4D4D' },
        { name: 'Astro', slug: 'astro', color: 'BC52EE' },
        { name: 'Hugo', slug: 'hugo', color: 'FF4088' },
        { name: 'WordPress', slug: 'wordpress', color: '21759B' },
        { name: 'Medium', slug: 'medium', color: '12100E' },
        { name: 'Substack', slug: 'substack', color: 'FF6719' },
        { name: 'X (Twitter)', slug: 'x', color: '000000' },
        { name: 'LinkedIn', slug: 'linkedin', color: '0A66C2' },
        { name: 'Facebook', slug: 'facebook', color: '0866FF' },
      ],
    }
  : {
      title: 'Works with everything you use',
      subtitle: 'CMS, static site tools, and social platforms',
      items: [
        { name: 'GitHub', slug: 'github', color: '000000' },
        { name: 'Lovable', slug: 'lovable', color: 'FF4D4D' },
        { name: 'Astro', slug: 'astro', color: 'BC52EE' },
        { name: 'Hugo', slug: 'hugo', color: 'FF4088' },
        { name: 'WordPress', slug: 'wordpress', color: '21759B' },
        { name: 'Medium', slug: 'medium', color: '12100E' },
        { name: 'Substack', slug: 'substack', color: 'FF6719' },
        { name: 'X (Twitter)', slug: 'x', color: '000000' },
        { name: 'LinkedIn', slug: 'linkedin', color: '0A66C2' },
        { name: 'Facebook', slug: 'facebook', color: '0866FF' },
      ],
    };

// Helper to build Simple Icons CDN URL
type Item = { name: string; slug: string; color: string };
const iconUrl = (i: Item) => `https://cdn.simpleicons.org/${encodeURIComponent(i.slug)}/${i.color}`;
---

<section id="works-with" class="py-16" style="background: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight" style="color: var(--text-primary);">{t.title}</h2>
      <p class="mt-2 text-base" style="color: var(--text-secondary);">{t.subtitle}</p>
    </div>

    <ul class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-6 items-center">
      {t.items.map((i) => (
        <li class="flex flex-col items-center justify-center gap-2" aria-label={i.name}>
          <div class="h-12 w-12 sm:h-14 sm:w-14 rounded-xl bg-white/70 dark:bg-white/10 ring-1 ring-black/5 dark:ring-white/10 flex items-center justify-center overflow-hidden">
            <img
              src={iconUrl(i)}
              alt={i.name}
              width={40}
              height={40}
              loading="lazy"
              class="h-8 w-8 sm:h-9 sm:w-9 object-contain"
            />
          </div>
          <span class="text-xs sm:text-sm font-medium text-center" style="color: var(--text-secondary);">{i.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
