---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro'
import I18n from '../features/i18n/I18n.astro';
export interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const siteUrl = import.meta.env.PUBLIC_SITE_URL as string | undefined;
const canonicalUrl = siteUrl ? new URL(pathname, siteUrl).toString() : undefined;
const ogLocale = 'en_US';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="CasysDB - An embedded graph database with ISO GQL support" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />
    <script>
      // Auto theme sync with system (no localStorage override)
      (function () {
        try {
          var root = document.documentElement;
          var mql = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function () {
            if (mql && mql.matches) root.classList.add('dark');
            else root.classList.remove('dark');
            root.dataset.theme = root.classList.contains('dark') ? 'dark' : 'light';
          };
          apply();
          if (mql && 'addEventListener' in mql) mql.addEventListener('change', apply);
          else if (mql && 'addListener' in mql) mql.addListener(apply);
        } catch (_) { /* no-op */ }
      })();
    </script>
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="CasysDB - An embedded graph database with ISO GQL support" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="CasysDB - An embedded graph database with ISO GQL support" />
  </head>
  <body class="min-h-screen" style="background: var(--bg-hero);">
    <!-- Header -->
    <header class="header-gradient border-b border-cassis-200 sticky top-0 z-50 backdrop-blur-md transition-transform duration-300 will-change-transform">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <div class="flex items-center">
            <div class="flex-shrink-0 flex items-center">
              <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
                <img src="/icons/logo.svg" class="h-8" alt="Casys Logo" />
                <span class="self-center text-2xl font-semibold whitespace-normal break-words leading-tight text-gray-900 dark:text-white">CasysDB</span>
              </a>
            </div>
          </div>

          <!-- Navigation -->
          <nav class="hidden md:flex space-x-8">
            <a href="/getting-started/installation/" class="text-gray-800 hover:text-gray-900 dark:text-white/80 dark:hover:text-white px-3 py-2 text-sm font-medium transition-colors">
              <I18n>
                <Fragment slot="en">Documentation</Fragment>
                <Fragment slot="fr">Documentation</Fragment>
              </I18n>
            </a>
            <a href="#examples" class="text-gray-800 hover:text-gray-900 dark:text-white/80 dark:hover:text-white px-3 py-2 text-sm font-medium transition-colors">
              <I18n>
                <Fragment slot="en">Examples</Fragment>
                <Fragment slot="fr">Exemples</Fragment>
              </I18n>
            </a>
            <a href="#branching" class="text-gray-800 hover:text-gray-900 dark:text-white/80 dark:hover:text-white px-3 py-2 text-sm font-medium transition-colors">
              <I18n>
                <Fragment slot="en">Branches</Fragment>
                <Fragment slot="fr">Branches</Fragment>
              </I18n>
            </a>
            <a href="#use-cases" class="text-gray-800 hover:text-gray-900 dark:text-white/80 dark:hover:text-white px-3 py-2 text-sm font-medium transition-colors">
              <I18n>
                <Fragment slot="en">Use Cases</Fragment>
                <Fragment slot="fr">Cas d'usage</Fragment>
              </I18n>
            </a>
            <a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="text-gray-800 hover:text-gray-900 dark:text-white/80 dark:hover:text-white px-3 py-2 text-sm font-medium transition-colors flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              <I18n>
                <Fragment slot="en">GitHub</Fragment>
                <Fragment slot="fr">GitHub</Fragment>
              </I18n>
            </a>
          </nav>

          <!-- Actions -->
          <div class="flex items-center space-x-2">
            <!-- Language switcher removed - automatic detection only -->
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background: var(--bg-main); color: var(--text-primary);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Company Info -->
          <div class="col-span-1 md:col-span-2">
            <h3 class="text-lg font-bold mb-4" style="color: var(--text-primary);">CasysDB</h3>
            <p class="mb-4" style="color: var(--text-secondary);">
              An embedded graph database with ISO GQL support. Built in Rust with native Python and TypeScript bindings.
              MVCC transactions, Point-in-Time Recovery, and a fluent ORM.
            </p>
            <p class="text-sm" style="color: var(--text-muted);">
              Fast, embedded, and powerful graph database
            </p>
          </div>

          <!-- Product -->
          <div>
            <h4 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">
              <I18n>
                <Fragment slot="en">Product</Fragment>
                <Fragment slot="fr">Produit</Fragment>
              </I18n>
            </h4>
            <ul class="space-y-2 text-sm" style="color: var(--text-secondary);">
              <li><a href="/getting-started/installation/" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Installation</a></li>
              <li><a href="/getting-started/quickstart/" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Quick Start</a></li>
              <li><a href="/gql/basics/" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">GQL Syntax</a></li>
              <li><a href="#features" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Features</a></li>
            </ul>
          </div>

          <!-- Community -->
          <div>
            <h4 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">
              <I18n>
                <Fragment slot="en">Community</Fragment>
                <Fragment slot="fr">Communauté</Fragment>
              </I18n>
            </h4>
            <ul class="space-y-2 text-sm" style="color: var(--text-secondary);">
              <li><a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">GitHub</a></li>
              <li><a href="https://github.com/casysai/casysdb/issues" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Issues</a></li>
              <li><a href="https://github.com/casysai/casysdb/discussions" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Discussions</a></li>
              <li><a href="/getting-started/installation/" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Documentation</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t mt-8 pt-8 flex flex-col md:flex-row justify-between items-center" style="border-color: var(--card-border);">
          <p class="text-sm" style="color: var(--text-muted);">
            © 2025 CasysDB. Open-source under MIT License.
          </p>
          <div class="flex space-x-6 mt-4 md:mt-0">
            <a href="https://github.com/casysai/casysdb/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-sm transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">MIT License</a>
            <a href="https://github.com/casysai/casysdb" target="_blank" rel="noopener noreferrer" class="text-sm transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">GitHub</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scripts pour les boutons -->
    <script>
      // Gestion du bouton de connexion (mock pour l'instant)
      document.getElementById('login-btn')?.addEventListener('click', () => {
        // Pour l'instant, redirection directe vers l'app
        // Plus tard : modal de connexion ou redirection vers auth
        window.location.href = '/app';
      });

      // Beta signup button handler
      document.getElementById('beta-signup-btn')?.addEventListener('click', () => {
        // For now: simple alert
        // Later: modal with form or API integration
        alert('Beta access request — coming soon!');
      });

      // Theme toggle handler with localStorage persistence
      (function () {
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const syncPressed = () => btn.setAttribute('aria-pressed', root.classList.contains('dark') ? 'true' : 'false');
        syncPressed();
        btn.addEventListener('click', () => {
          const isDark = root.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          root.dataset.theme = isDark ? 'dark' : 'light';
          syncPressed();
        });
      })();
    </script>

    <!-- Hide-on-scroll logic for header -->
    <script>
      (function () {
        const header = document.querySelector('header.header-gradient');
        if (!header) return;
        let lastY = window.scrollY;
        let ticking = false;
        const threshold = 8; // pixels

        const onScroll = () => {
          const currentY = window.scrollY;
          const delta = currentY - lastY;
          const goingDown = delta > 0;
          const farFromTop = currentY > 10;
          if (Math.abs(delta) > threshold) {
            if (goingDown && farFromTop) {
              header.classList.add('hide-nav');
            } else {
              header.classList.remove('hide-nav');
            }
            lastY = currentY;
          }
          ticking = false;
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(onScroll);
            ticking = true;
          }
        }, { passive: true });
      })();
    </script>

    <style>
      /* Header transparent pour continuité du gradient */
      .header-gradient { backdrop-filter: blur(10px); }
      /* Light header */
      :root:not(.dark) .header-gradient { background: rgba(255, 255, 255, 0.6); border-color: rgba(17, 24, 39, 0.1); }
      /* Dark header */
      .dark .header-gradient { background: rgba(0, 0, 0, 0.1); border-color: rgba(204, 102, 204, 0.2); }
      /* Hide-on-scroll behavior */
      .hide-nav { transform: translateY(-100%); }

      /* Gradient pour le texte CASYS */
      .brand-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #e6b3ff 20%, #cc66cc 60%, #8b008b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Bouton cassis */
      .btn-cassis {
        background: linear-gradient(135deg, #2d1b69 0%, #8b5a87 100%);
        border: 1px solid rgba(204, 102, 204, 0.3);
        transition: all 0.3s ease;
      }

      .btn-cassis:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(139, 90, 135, 0.4);
        border-color: rgba(204, 102, 204, 0.5);
      }

      /* Couleurs cassis personnalisées */
      .text-cassis-200 {
        color: rgba(230, 179, 255, 0.8);
      }

      .border-cassis-200 {
        border-color: rgba(204, 102, 204, 0.2);
      }

      /* Gradient de fond pour toute la page */
      .gradient-body {
        background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 30%, #fde68a 70%, #fff 100%);
        background-attachment: fixed;
      }

      .dark .gradient-body {
        background: linear-gradient(135deg, #000000 0%, #2d1b69 30%, #4a1a4a 70%, #1a0a1a 100%);
        background-attachment: fixed;
      }
    </style>

    <Analytics />
  </body>
</html>
